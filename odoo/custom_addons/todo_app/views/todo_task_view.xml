<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_todo_task_list" model="ir.ui.view">
        <field name="name">todo.task.list</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
<list string="Tasks" decoration-danger="is_due_today"> 
                <field name="name"/>
                <field name="due_date"/>
                <field name="assigned_to"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_todo_task_form" model="ir.ui.view">
        <field name="name">todo.task.form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <header>
                    <button name="action_set_closed" type="object" string="Close" invisible="state == 'completed'" 
                        class="oe_highlight"
                        confirm="Are you sure you want to close this task? This action cannot be undone."
                        title="Close Task"
                    ></button>
                    <button name="action_set_in_progress" type="object" string="Set In Progress" invisible="state != 'new'" class="oe_highlight"/>
                    <button name="action_set_completed" type="object" string="Set Completed" invisible="state != 'in_progress'" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="due_date"/>
                            <field name="assigned_to"/>
                            <field name="state"/>
                            <field name="description"/>
                            <field name="estimated_hours"/>
                            <field name="actual_hours" readonly="1"/>
                        </group>
                        <notebook>
                            <page name="Timesheets" string="Timesheets">
                                <field name="timesheet_ids" context="{'default_task_id': id}">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="hours_spent"/>
                                        <field name="description"/>
                                    </list>
                                    <form>
                                        <group>
                                            <field name="date"/>
                                            <field name="hours_spent"/>
                                            <field name="description"/>
                                        </group>
                                    </form>
                                </field>
                                
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>

    </record>

    <!-- Search View -->
    <record id="view_todo_task_search" model="ir.ui.view">
        <field name="name">todo.task.search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <field name="name"/>
                <field name="assigned_to"/>
                <filter string="New" name="state_new" domain="[('state','=','new')]"/>
                <filter string="In Progress" name="state_in_progress" domain="[('state','=','in_progress')]"/>
                <filter string="Completed" name="state_completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_todo_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">todo.task</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first task!
            </p>
            <p>
                Click the "New" button to create a new task.
            </p>
        </field>
    </record>
</odoo>
