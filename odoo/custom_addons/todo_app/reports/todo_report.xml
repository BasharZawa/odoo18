<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="todo_report" model="ir.actions.report">
        <field name="name">Todo Report</field>
        <field name="model">todo.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="binding_type">report</field>
        <field name="report_name">todo_app.todo_report_template</field>
    </record>
    
    <template id="todo_report_template" name="todo_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="doc">
                    <p>Due Date: <t t-esc="doc.due_date"/></p>
                    <p>Assigned To: <t t-esc="doc.assigned_to.name"/></p>
                    <p>Status: <t t-esc="doc.state"/></p>
                    <p>Description: <t t-esc="doc.description"/></p>
                    <p>Estimated Hours: <t t-esc="doc.estimated_hours"/></p>
                    <p>Actual Hours: <t t-esc="doc.actual_hours"/></p>
                    <h3>Timesheets</h3>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>   
                                <th>Hours Spent</th>
                                <th>Description</th>
                            </tr>
                        </thead>    
                        <tbody>
                            <t t-foreach="doc.timesheet_ids" t-as="timesheet">
                                <tr>
                                    <td><t t-esc="timesheet.date"/></td>
                                    <td><t t-esc="timesheet.hours_spent"/></td>
                                    <td><t t-esc="timesheet.description"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </t>
        </t>
    </template>

</odoo>
