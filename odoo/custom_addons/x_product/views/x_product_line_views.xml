<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Line list View -->
    <record id="view_x_product_line_list" model="ir.ui.view">
        <field name="name">x.product.line.list</field>
        <field name="model">x.product.line</field>
        <field name="arch" type="xml">
            <list string="Product Line">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Product Line Form View -->
    <record id="view_x_product_line_form" model="ir.ui.view">
        <field name="name">x.product.line.form</field>
        <field name="model">x.product.line</field>
        <field name="arch" type="xml">
            <form string="Product Line">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Related Products">
                            <field name="x_product_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="default_code"/>
                                    <field name="list_price"/>
                                    <field name="uom_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product Line Action -->
    <record id="action_x_product_line" model="ir.actions.act_window">
        <field name="name">Product Line</field>
        <field name="res_model">x.product.line</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Product Line
            </p>
            <p>
                Define different product lines to categorize your products.
            </p>
        </field>
    </record>
</odoo>
