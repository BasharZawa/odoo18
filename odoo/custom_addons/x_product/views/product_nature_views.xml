<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Nature list View -->
    <record id="view_product_nature_list" model="ir.ui.view">
        <field name="name">product.nature.list</field>
        <field name="model">product.nature</field>
        <field name="arch" type="xml">
            <list string="Product Nature">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Product Nature Form View -->
    <record id="view_product_nature_form" model="ir.ui.view">
        <field name="name">product.nature.form</field>
        <field name="model">product.nature</field>
        <field name="arch" type="xml">
            <form string="Product Nature">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="product_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="default_code"/>
                                    <field name="list_price"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product Nature Action -->
    <record id="action_product_nature" model="ir.actions.act_window">
        <field name="name">Product Nature</field>
        <field name="res_model">product.nature</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Product Nature
            </p>
            <p>
                Define different product natures to categorize your products.
            </p>
        </field>
    </record>
</odoo>
