<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--Auto cron job for process for sending email for Low stock products-->
        <record id="email_notification_for_low_stock_product" model="ir.cron">
            <field name="name">Product: Email Notification For Low Stock </field>
            <field name="model_id" ref="model_product_product"/>
            <field name="state">code</field>
            <field eval="False" name="active"/>
                <field name="code">model.auto_email_for_low_stock_product()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

        <record id="email_notification_for_replenish_review_reminder" model="ir.cron">
            <field name="name">Replenish: Monthly review reminder</field>
            <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
            <field name="state">code</field>
            <field eval="False" name="active"/>
                <field name="code">model.auto_email_for_replenish_review_reminder()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
