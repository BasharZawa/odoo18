<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_delivery_document_pack_slip_inherited" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@class='page']/h2" position="replace">
            <t t-if="is_packing_slip">
                <h2 style="text-align:center; margin-bottom: 20px;">
                    <span style="color:#5d4765;text-decoration: underline;">PACKING SLIP</span>
                </h2>
            </t>
            <t t-else="">
                <h2 style="text-align:center; margin-bottom: 20px;">
                    <span style="color:#5d4765;text-decoration: underline;">DELIVERY SLIP</span>
                </h2>
            </t>
            <h3>
                <span t-field="o.name">WH/OUT/0001</span>
            </h3>
        </xpath>
        <xpath expr="//div[@id='informations']" position="inside">
            <t t-set="invoices"
               t-value="o.move_ids.mapped('sale_line_id.invoice_lines.move_id.name') if o.picking_type_id.code == 'outgoing' else o.move_ids.mapped('purchase_line_id.invoice_lines.move_id.name')"/>
            <div t-if="invoices" class="col col-3 mw-100 mb-2" name="div_origin">
                <t t-if="o.picking_type_id.code == 'outgoing'">
                    <strong>Invoice Number</strong>
                </t>
                <t t-else="">
                    <strong>Bill Number</strong>
                </t>
                <div class="m-0">
                    <t t-esc="', '.join(invoices)"/>
                </div>
            </div>
            <div t-if="o.user_id and not is_packing_slip" class="col col-3 mw-100 mb-2" name="div_origin">
                <strong>Attention</strong>
                <div class="m-0">
                    <t t-esc="o.user_id.name"/>
                </div>
            </div>
            <div t-if="o.bayan_code" class="col col-3 mw-100 mb-2" name="div_origin">
                <strong>BOE Number</strong>
                <div class="m-0">
                    <t t-esc="o.bayan_code"/>
                </div>
            </div>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/thead/tr" position="inside">
            <th t-if='is_packing_slip' name="th_prod_weight" class="text-end">Weight</th>
        </xpath>
        <xpath expr="//table[@name='stock_move_table']/tbody/tr" position="inside">
            <td t-if='is_packing_slip' class="text-end" name="move_line_total_weight">
                <t t-set="product_weight" t-value="move.product_id.weight * move.product_uom_qty"/>
                <span t-esc="product_weight or 0"/>
                <span t-esc="o.weight_uom_name"/>
            </td>
        </xpath>

        <xpath expr="//table[@name='stock_move_line_table']/thead/tr" position="inside">
            <th t-if='is_packing_slip' name="th_prod_weight" class="text-center">Weight</th>
        </xpath>

        <xpath expr="//tr[@t-foreach='package_move_lines']/t[@t-call='stock.stock_report_delivery_has_serial_move_line']"
               position="replace">
            <t t-call="stock.stock_report_delivery_has_serial_move_line">
                <t t-set="is_packing_slip" t-value="True"/>
            </t>
        </xpath>
        <!--        #-->
        <xpath expr="//tr[@t-foreach='package_move_lines']/t[@t-call='stock.stock_report_delivery_has_serial_move_line']"
               position="replace">
            <t t-call="stock.stock_report_delivery_has_serial_move_line">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <xpath expr="//tr[@t-foreach='move_lines']/t[@t-call='stock.stock_report_delivery_has_serial_move_line']"
               position="replace">
            <t t-call="stock.stock_report_delivery_has_serial_move_line">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <xpath expr="//tr[@t-foreach='o.move_line_ids']/t[@t-call='stock.stock_report_delivery_has_serial_move_line']"
               position="replace">
            <t t-call="stock.stock_report_delivery_has_serial_move_line">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <!--        #-->

        <!--        #-->
        <xpath expr="//table[@name='stock_move_line_table']//t[@t-foreach='packages']//t[@t-call='stock.stock_report_delivery_aggregated_move_lines']"
               position="replace">
            <t t-call="stock.stock_report_delivery_aggregated_move_lines">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <xpath expr="//t[@t-if='move_lines or aggregated_lines']//t[@t-call='stock.stock_report_delivery_aggregated_move_lines']"
               position="replace">
            <t t-call="stock.stock_report_delivery_aggregated_move_lines">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <xpath expr="//t[@t-else='' and @name='aggregated_move_lines']/t[@t-call='stock.stock_report_delivery_aggregated_move_lines']"
               position="replace">
            <t t-call="stock.stock_report_delivery_aggregated_move_lines">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <!--        #-->

        <!--        #-->
        <xpath expr="//t[@t-foreach='packages']//t[@t-call='stock.stock_report_delivery_package_section_line']"
               position="replace">
            <t t-call="stock.stock_report_delivery_package_section_line">
                <t t-set="is_packing_slip" t-value="is_packing_slip"/>
            </t>
        </xpath>
        <!--        #-->

        <!--        #-->
        <xpath expr="//th[@name='th_sm_ordered']" position="attributes">
            <attribute name="t-attf-class" add="#{'d-none' if is_packing_slip else ''}"/>
        </xpath>
        <xpath expr="//th[@name='th_sml_qty_ordered']" position="attributes">
            <attribute name="t-attf-class" add="#{'d-none' if is_packing_slip else 'text-center'}"/>
        </xpath>


        <xpath expr="//span[@t-field='move.product_uom_qty']/.." position="attributes">
            <attribute name="t-attf-class" add="#{'d-none' if is_packing_slip else 'text-end'}"/>
        </xpath>
        <!--        #-->

        <xpath expr="//div[@class='page']" position="inside">
            <div t-if="not is_packing_slip" style="margin-top: 30px; page-break-inside: avoid">
                <table style="width:100%; border-collapse: collapse; border: 1px solid #000; font-size:14px;">
                    <tr>
                        <td colspan="3" style="border: 1px solid #000; padding: 6px; font-weight: bold;">
                            Goods received in good order
                        </td>
                    </tr>
                    <tr style="height: 50px;">
                        <td style="border: 1px solid #000; padding: 8px; width: 33%;  border-right: 0px;">
                            Name :
                            <span style="display: inline-block; margin-left: 10px; position: relative; top: 10px;">
                                ______________________
                            </span>
                        </td>
                        <td style="border: 1px solid #000; padding: 8px; width: 33%; border-left: 0px; border-right: 0px;">
                            Signature :
                            <span style="display: inline-block; margin-left: 10px; position: relative; top: 10px;">
                                ______________________
                            </span>
                        </td>
                        <td style="border: 1px solid #000; padding: 8px; width: 34%; border-left: 0px;">
                            Date :
                            <span style="display: inline-block; margin-left: 10px; position: relative; top: 10px;">
                                ______________________
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </xpath>

    </template>

    <template id="stock_report_delivery_has_serial_move_line_pack_slip_inherited"
              inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//td[@name='move_line_lot_quantity']" position="after">
            <t t-if="is_packing_slip">
                <t t-set="product_weight"
                   t-value="move_line.move_id.product_id.weight * move_line.move_id.product_uom_qty"/>
                <td class="text-center" name="move_line_total_weight">
                    <span t-esc="product_weight or 0"/>
                    <span t-esc="o.weight_uom_name"/>
                </td>
            </t>
        </xpath>
    </template>

    <template id="stock_report_delivery_aggregated_move_lines_pack_slip_inherited"
              inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//td[@name='move_line_aggregated_quantity']" position="after">
            <t t-if="is_packing_slip">
                <t t-set="product_weight"
                   t-value="aggregated_lines[line].get('product').weight * aggregated_lines[line].get('quantity')"/>
                <td class="text-center" name="move_line_total_weight">
                    <span t-esc="product_weight or 0"/>
                    <span t-esc="o.weight_uom_name"/>
                </td>
            </t>
        </xpath>
        <xpath expr="//td[@name='move_line_aggregated_qty_ordered']" position="attributes">
            <attribute name="t-attf-class" add="#{'d-none' if is_packing_slip else 'text-center'}"/>
        </xpath>

    </template>

    <template id="stock_report_delivery_package_section_line_pack_slip_inherited"
              inherit_id="stock.stock_report_delivery_package_section_line">
        <xpath expr="//td[@name='package_info']" position="inside">
            <t t-if="is_packing_slip">
                <t t-set="package_type" t-value="package.package_type_id"/>
                <t t-if="any([package_type.packaging_length, package_type.width, package_type.height])">
                    -
                    <span t-esc="package_type.packaging_length or 0"/>
                    x
                    <span t-esc="package_type.width or 0"/>
                    x
                    <span t-esc="package_type.height or 0"/>
                    <span t-esc="package_type.length_uom_name or ''"/>
                </t>
            </t>
        </xpath>
    </template>

    <template id="report_packing_slip">
        <t t-foreach="docs" t-as="o">
            <t t-call="stock.report_delivery_document" t-lang="o._get_report_lang()">
                <t t-set="is_packing_slip" t-value="True"/>
            </t>
        </t>
    </template>
</odoo>
