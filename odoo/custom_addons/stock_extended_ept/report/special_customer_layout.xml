<odoo>
    <template id="special_customer_external_layout" inherit_id="web.external_layout_standard">
        <xpath expr="//img[@class='o_company_logo_small']/.." position="replace">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <t t-if="o._context.get('active_model') == 'stock.picking'">
                    <t t-if="o.partner_id.is_special_customer">
                        <div style="padding-top: 4pt; padding-bottom: 2pt; width: 100%;">
                            <img t-att-src="image_data_uri(o.partner_id.header_img)"
                                 style="width: 100%;" alt="Company Logo"/>
                        </div>
                    </t>
                    <t t-elif="o.company_id.header_img">
                        <div style="padding-top: 4pt; padding-bottom: 2pt; width: 100%;">
                            <img t-att-src="image_data_uri(o.company_id.header_img)"
                                 style="width: 100%;" alt="Company Logo"/>
                        </div>
                    </t>
                    <t t-else="">
                        <img t-if="company.logo" class="o_company_logo_small" t-att-src="image_data_uri(company.logo)"
                         alt="Logo"/>
                        <div t-if="company.report_header" t-field="company.report_header"
                             class="o_company_tagline mw-50 fw-bold">Company tagline
                        </div>
                    </t>
                </t>
                <t t-else="">
                    <img t-if="company.logo" class="o_company_logo_small" t-att-src="image_data_uri(company.logo)"
                         alt="Logo"/>
                    <div t-if="company.report_header" t-field="company.report_header"
                         class="o_company_tagline mw-50 fw-bold">Company tagline
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="replace">
            <t t-if="o._context.get('active_model') == 'stock.picking'">
                <t t-if="o.partner_id.is_special_customer">
                    <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}">
                        <div class="o_footer_content d-flex border-top pt-2">
                            <div style="padding-top: 4pt; padding-bottom: 2pt; width: 100%;">
                                <img t-att-src="image_data_uri(o.partner_id.footer_img)"
                                     style="width: 100%;" alt="Company Logo"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
            <t t-else="">
                <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}">
                    <div class="o_footer_content d-flex border-top pt-2">
                        <div class="flex-grow-1 text-start me-2" t-field="company.report_footer"/>
                        <div class="text-end text-muted">
                            <div t-if="report_type == 'pdf' and display_name_in_footer" t-out="o.name">(document name)
                            </div>
                            <div t-if="report_type == 'pdf'">Page
                                <span class="page"/>
                                /
                                <span class="topage"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
