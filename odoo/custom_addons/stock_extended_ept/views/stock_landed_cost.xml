<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_landed_cost_form_inherit_manual_cost" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.inherit.manual.cost</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vendor_bill_id']" position="after">
                <label for="lc_currency_id"/>
                <div class="o_row">
                    <field name="lc_currency_id" string="Currency" widget="selection" readonly="state != 'draft'"
                           context="{'search_default_active': 1, 'search_default_inactive': 1}"/>
                    <div name="currency_conversion_div" class="d-flex gap-1 text-muted"
                         invisible="lc_currency_id == currency_id">
                        <span>(1</span>
                        <field name="currency_id" readonly="True" options="{'no_open': True}" class="w-auto"/>
                        <span>=</span>
                        <field name="invoice_currency_rate" class="oe_inline" digits="[12,6]"/>
                        <field name="lc_currency_id" readonly="1" options="{'no_open': True}" class="w-auto"/>
                        <span>)</span>
                    </div>
                </div>
            </xpath>

            <xpath expr="//field[@name='cost_lines']/list/field[@name='price_unit']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

            <xpath expr="//field[@name='cost_lines']/list/field[@name='price_unit']" position="after">
                <field name="lc_line_currency_id" column_invisible="True"/>
                <field name="manual_added_cost" string="Cost in Currency"/>
                <button name="action_update_cost" string="Update" type="object" icon="fa-refresh"
                        invisible="manual_added_cost == 0 or is_cost_synced" title="Copy manual cost to price unit"/>
            </xpath>

            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="lc_currency_id" invisible="True"/>
                <field name="manual_cost_total" string="Total in Currency" widget="monetary"/>
            </xpath>
        </field>
    </record>
</odoo>
