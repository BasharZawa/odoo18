<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bayan_code_stock_picking_form_view" model="ir.ui.view">
        <field name="name">Bayan Code Stock Picking</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="button_create_landed_costs" string="Create Landed Costs" type="object"
                        class="oe_highlight" data-hotkey="l"
                        invisible="picking_type_code != 'incoming' or state != 'done'"/>
            </xpath>
            <div name="button_box" position="inside">
                <button string="Landed Costs" type="object"
                    name="action_view_landed_costs"
                    class="oe_stat_button" icon="fa-plus-square"
                    invisible="landed_cost_count == 0">
                    <field name="landed_cost_count" widget="statinfo" string="Landed Costs"/>
                </button>
            </div>
            <field name="backorder_id" position="after">
                <field name="bayan_code" invisible="picking_type_code != 'incoming' or not is_bayan_code_visible"
                       readonly="state in ['done', 'cancel']"/>
            </field>
        </field>
    </record>

    <!-- Server action that appears in Print menu -->
    <record id="action_print_packing_slip_xlsx" model="ir.actions.server">
        <field name="name">Packing Slip XLSX</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="groups_id" eval="[(4, ref('stock.group_stock_user'))]"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="state">code</field>
        <field name="code">
            if records:
            action = records.action_download_packing_slip_xlsx_report()
        </field>
    </record>
</odoo>
