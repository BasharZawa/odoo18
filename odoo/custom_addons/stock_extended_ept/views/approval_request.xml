<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="approval_request_adjustment_view_form_inherit" model="ir.ui.view">
        <field name="name">approval.request.adjustment.view.form.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <field name="quantity" position="before">
                <field name="has_adjustment_product" invisible="1"/>
                <field name="has_adjustment_location" invisible="1"/>
                <field name="stock_quant_product_id" invisible="has_adjustment_product == 'no'"
                       required="has_adjustment_product != 'no'"/>
                <field name="stock_quant_location_id" invisible="has_adjustment_location == 'no'"
                       required="has_adjustment_location != 'no'"/>
            </field>
        </field>
    </record>
</odoo>
