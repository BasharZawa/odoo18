<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="special_customer_view_form_inherit" model="ir.ui.view">
        <field name="name">special.customer.view.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
<!--            <field name="vat" position="after">-->
<!--                <field name="is_special_customer"/>-->
<!--                <field name="header_img" widget="image" invisible="not is_special_customer"-->
<!--                       required="is_special_customer"/>-->
<!--                <field name="footer_img" widget="image" invisible="not is_special_customer"-->
<!--                       required="is_special_customer"/>-->
<!--            </field>-->
            <xpath expr="//field[@name='vat']/../.." position="inside">
                <field name="is_special_customer"/>
                <field name="header_img" widget="image" invisible="not is_special_customer" required="is_special_customer"/>
                <field name="footer_img" widget="image" invisible="not is_special_customer" required="is_special_customer"/>
            </xpath>
        </field>
    </record>
</odoo>
