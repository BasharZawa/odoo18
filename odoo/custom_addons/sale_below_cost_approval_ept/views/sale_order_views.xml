<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_form_below_cost" model="ir.ui.view">
            <field name="name">sale.order.form.below.cost</field>
            <field name="model">sale.order</field>
            <field name="priority">100</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <field name="user_id" position="after">
                    <field name="has_below_cost_approved" invisible="1"/>
                </field>
                <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                    <field name="below_cost" column_invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
