<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sale_below_cost_wizard_form" model="ir.ui.view">
            <field name="name">sale.below.cost.wizard.form</field>
            <field name="model">sale.below.cost.wizard</field>
            <field name="arch" type="xml">
                <form string="Below-Cost Approval">
                    <sheet>
                        <group>
                            <field name="order_id" readonly="1"/>
                            <field name="below_lines_info" readonly="1" nolabel="1"/>
                            <field name="reason" placeholder="Explain the price discrepancy"/>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Request Approval" class="btn-primary" type="object"
                                name="action_request_approval"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>

