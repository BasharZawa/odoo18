<odoo>
  <record id="ir_cron_orchestrator" model="ir.cron">
    <field name="name">BPM Orchestrator Tick</field>
    <field name="model_id" ref="model_orchestrator_helper"/>
    <field name="state">code</field>
    <field name="code">model.cron_tick()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">minutes</field>
    <field name="active">True</field>
  </record>
  <record id="ir_cron_outbox" model="ir.cron">
    <field name="name">BPM Outbox Dispatcher</field>
    <field name="model_id" ref="model_orchestrator_helper"/>
    <field name="state">code</field>
    <field name="code">model.cron_dispatch_outbox()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">minutes</field>
    <field name="active">True</field>
  </record>
  <record id="ir_cron_timers" model="ir.cron">
    <field name="name">BPM Timers</field>
    <field name="model_id" ref="model_orchestrator_helper"/>
    <field name="state">code</field>
    <field name="code">model.cron_fire_due_timers()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">minutes</field>
    <field name="active">True</field>
  </record>
</odoo>
