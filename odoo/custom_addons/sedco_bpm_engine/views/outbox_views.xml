<odoo>
  <record id="view_outbox_list" model="ir.ui.view">
    <field name="name">outbox.list</field>
    <field name="model">outbox</field>
    <field name="arch" type="xml">
      <list string="Outbox">
        <field name="kind"/>
        <field name="dedup_key"/>
        <field name="payload"/>
        <field name="created_at"/>
        <field name="dispatched_at"/>
        <field name="status"/>
        <field name="last_error"/>
      </list>
    </field>
  </record>

  <record id="action_outbox" model="ir.actions.act_window">
    <field name="name">Outbox</field>
    <field name="res_model">outbox</field>
    <field name="view_mode">list</field>
  </record>
</odoo>
