<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Process Definition Activity Views -->
    
    <!-- List View -->
    <record id="view_process_definition_activity_list" model="ir.ui.view">
        <field name="name">process.definition.activity.list</field>
        <field name="model">process.definition.activity</field>
        <field name="arch" type="xml">
            <list string="Process Activities" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="node_id"/>
                <field name="name"/>
                <field name="type"/>
                <field name="assignee_role_id" optional="show"/>
                <field name="service_action" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="definition_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_process_definition_activity_form" model="ir.ui.view">
        <field name="name">process.definition.activity.form</field>
        <field name="model">process.definition.activity</field>
        <field name="arch" type="xml">
            <form string="Process Activity">
                <header>
                    <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" required="1" placeholder="Activity Name"/>
                        </h1>
                        <h3>
                            <field name="node_id" required="1" placeholder="Node ID (e.g., Task_1)"/>
                        </h3>
                    </div>
                    
                    <group>
                        <group name="basic_info">
                            <field name="definition_id" readonly="1"/>
                            <field name="sequence"/>
                            <field name="type" required="1"/>
                            <field name="description"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <!-- Flow Control Tab -->
                        <page string="Flow Control" name="flow">
                            <group>
                                <group name="basic_flow" string="Basic Flow" invisible="type in ['pbranch']">
                                    <field name="next_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"/>
                                </group>
                                
                                <group name="multiple_flow" string="Multiple Next Activities" invisible="type not in ['start']">
                                    <field name="next_activity_ids" widget="many2many_tags"
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Task Configuration Tab -->
                        <page string="Task Configuration" name="task_config" invisible="type != 'task'">
                            <group>
                                <group name="assignee_config" string="Assignment">
                                    <field name="assignee_role_id"/>
                                </group>
                                
                                <group name="approval_routing" string="Approval Routing">
                                    <field name="next_approve_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"/>
                                    <field name="next_reject_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Service Task Configuration -->
                        <page string="Service Configuration" name="service_config" invisible="type != 'sys'">
                            <group>
                                <group name="service_info" string="Service Action">
                                    <field name="service_action" required="1" 
                                           placeholder="my_module.actions.my_function"
                                           help="Enter the dotted path to your registered service function"/>
                                    <div class="text-muted" style="margin-top: 8px;">
                                        <i class="fa fa-info-circle"/> 
                                        Service actions must be registered in the BPM Registry for security.
                                        Contact your administrator to register new functions.
                                    </div>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Gateway Configuration -->
                        <page string="Gateway Configuration" name="gateway_config" invisible="type != 'if'">
                            <group>
                                <group name="condition" string="Condition">
                                    <field name="condition_expression" widget="text" required="1" 
                                           placeholder="ctx.get('amount', 0) > 1000"
                                           help="Python expression that evaluates to True/False"/>
                                </group>
                                
                                <group name="routing" string="Routing">
                                    <field name="true_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"
                                           string="When True"/>
                                    <field name="false_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"
                                           string="When False"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Parallel Gateway Configuration -->
                        <page string="Parallel Configuration" name="parallel_config" invisible="type not in ['pbranch', 'pwait']">
                            <group invisible="type != 'pbranch'">
                                <group name="parallel_split" string="Parallel Split Configuration">
                                    <field name="branch_activity_ids" widget="many2many_tags"
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id)]"
                                           string="Branch Activities"
                                           help="Activities to execute in parallel"/>
                                    <field name="join_activity_id" 
                                           context="{'default_definition_id': definition_id}"
                                           domain="[('definition_id', '=', definition_id), ('id', '!=', id), ('type', '=', 'pwait')]"
                                           string="Join Point"
                                           help="Parallel Gateway (Join) that waits for all branches"/>
                                </group>
                            </group>
                            
                            <group invisible="type != 'pwait'">
                                <group name="parallel_join" string="Parallel Join Configuration">
                                    <div class="alert alert-info">
                                        <strong>Parallel Gateway (Join)</strong><br/>
                                        This activity will wait for all parallel branches to complete before proceeding.
                                    </div>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Timer Configuration -->
                        <page string="Timer Configuration" name="timer_config" invisible="type != 'wtime'">
                            <group>
                                <group name="delay_config" string="Delay Configuration">
                                    <field name="delay_days"/>
                                    <field name="delay_hours"/>
                                    <field name="delay_minutes"/>
                                    <field name="delay_seconds"/>
                                    <separator colspan="2"/>
                                    <field name="total_delay_seconds" readonly="1" string="Total Delay (seconds)"/>
                                </group>
                                
                                <group name="delay_help" string="Examples">
                                    <div class="text-muted">
                                        <ul>
                                            <li><strong>1 day delay:</strong> Days = 1</li>
                                            <li><strong>2 hours delay:</strong> Hours = 2</li>
                                            <li><strong>30 minutes:</strong> Minutes = 30</li>
                                            <li><strong>Mixed:</strong> Days = 1, Hours = 2, Minutes = 30</li>
                                        </ul>
                                    </div>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Event Configuration -->
                        <page string="Event Configuration" name="event_config" invisible="type not in ['wevent', 'wcond']">
                            <group invisible="type != 'wevent'">
                                <group name="message_event" string="Message Event Configuration">
                                    <field name="event_name" required="1" placeholder="client.approved"
                                           help="Name of the event to wait for"/>
                                    <field name="correlation_key" placeholder="request_id"
                                           help="Key to correlate this event with process instance"/>
                                </group>
                                
                                <group name="event_help" string="Help">
                                    <div class="text-muted">
                                        <p><strong>Event Name:</strong> Unique identifier for the event type</p>
                                        <p><strong>Correlation Key:</strong> Field that links the event to this specific process instance</p>
                                        <p><strong>Example:</strong> Wait for "payment.confirmed" event with correlation_key matching record ID</p>
                                    </div>
                                </group>
                            </group>
                            
                            <group invisible="type != 'wcond'">
                                <group name="conditional_event" string="Conditional Event Configuration">
                                    <field name="condition_expression" widget="text" required="1"
                                           placeholder="ctx.get('status') == 'approved'"
                                           help="Python expression to evaluate periodically"/>
                                </group>
                                
                                <group name="condition_help" string="Help">
                                    <div class="text-muted">
                                        <p>This activity will wait until the condition becomes True.</p>
                                        <p>The condition is checked periodically by the BPM engine.</p>
                                        <p><strong>Example:</strong> <code>record.state == 'done'</code></p>
                                    </div>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Advanced Configuration -->
                        <page string="Advanced" name="advanced">
                            <group>
                                <group name="custom_config" string="Custom Configuration">
                                    <field name="custom_data" widget="ace" options="{'mode': 'json'}"
                                           help="Additional configuration data in JSON format"/>
                                </group>
                                
                                <group name="json_help" string="Help">
                                    <div class="text-muted">
                                        <p>Use this field to store activity-specific configuration that doesn't fit in standard fields.</p>
                                        <p><strong>Example:</strong></p>
                                        <pre>{
  "email_template": "approval_request",
  "cc_users": ["user1", "user2"],
  "priority": "high"
}</pre>
                                    </div>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_process_definition_activity_search" model="ir.ui.view">
        <field name="name">process.definition.activity.search</field>
        <field name="model">process.definition.activity</field>
        <field name="arch" type="xml">
            <search string="Process Activities">
                <field name="name"/>
                <field name="node_id"/>
                <field name="definition_id"/>
                <field name="type"/>
                <field name="assignee_role_id"/>
                
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                
                <separator/>
                <filter string="Start Events" name="start_events" domain="[('type', '=', 'start')]"/>
                <filter string="End Events" name="end_events" domain="[('type', '=', 'end')]"/>
                <filter string="User Tasks" name="user_tasks" domain="[('type', '=', 'task')]"/>
                <filter string="Service Tasks" name="service_tasks" domain="[('type', '=', 'sys')]"/>
                <filter string="Exclusive Gateways" name="exclusive_gateways" domain="[('type', '=', 'if')]"/>
                <filter string="Parallel Gateways" name="parallel_gateways" domain="[('type', 'in', ['pbranch', 'pwait'])]"/>
                <filter string="Timer Events" name="timer_events" domain="[('type', '=', 'wtime')]"/>
                <filter string="Message Events" name="message_events" domain="[('type', '=', 'wevent')]"/>
                <filter string="Conditional Events" name="conditional_events" domain="[('type', '=', 'wcond')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Process Definition" name="group_definition" context="{'group_by': 'definition_id'}"/>
                    <filter string="Activity Type" name="group_type" context="{'group_by': 'type'}"/>
                    <filter string="BPM Role" name="group_role" context="{'group_by': 'assignee_role_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_process_definition_activity" model="ir.actions.act_window">
        <field name="name">Process Activities</field>
        <field name="res_model">process.definition.activity</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_process_definition_activity_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first process activity!
            </p>
            <p>
                Activities define the individual steps in your business process workflow.
                Each activity represents a node in your BPMN diagram and can be:
            </p>
            <ul>
                <li><strong>User Tasks:</strong> Require human interaction (approvals, reviews)</li>
                <li><strong>Service Tasks:</strong> Automated system actions (emails, calculations)</li>
                <li><strong>Gateways:</strong> Control process flow (conditions, parallel execution)</li>
                <li><strong>Events:</strong> Process triggers and waiting points</li>
            </ul>
        </field>
    </record>

</odoo>