<odoo>
  <record id="view_process_instance_form" model="ir.ui.view">
    <field name="name">process.instance.form</field>
    <field name="model">process.instance</field>
    <field name="arch" type="xml">
      <form string="Process Instance">
        <sheet>
          <group>
            <field name="definition_id"/>
            <field name="business_key"/>
            <field name="status"/>
          </group>
          <group>
            <field name="ctx_json" widget="text"/>
          </group>
          <notebook>
            <page string="Activities">
              <field name="activity_ids">
                <list editable="bottom">
                  <field name="node_id"/>
                  <field name="type"/>
                  <field name="status"/>
                  <field name="assignee_id"/>
                  <field name="started_at"/>
                  <field name="ended_at"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="view_process_instance_list" model="ir.ui.view">
    <field name="name">process.instance.list</field>
    <field name="model">process.instance</field>
    <field name="arch" type="xml">
      <list string="Process Instances">
        <field name="definition_id"/>
        <field name="business_key"/>
        <field name="status"/>
        <field name="create_date"/>
        <field name="write_date"/>
      </list>
    </field>
  </record>

  <record id="action_process_instance" model="ir.actions.act_window">
    <field name="name">Process Instances</field>
    <field name="res_model">process.instance</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
