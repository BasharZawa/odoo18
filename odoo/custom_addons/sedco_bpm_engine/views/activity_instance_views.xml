<odoo>
  <record id="view_activity_instance_list" model="ir.ui.view">
    <field name="name">activity.instance.list</field>
    <field name="model">activity.instance</field>
    <field name="arch" type="xml">
      <list string="Activity Instances">
        <field name="proc_id"/>
        <field name="node_id"/>
        <field name="type"/>
        <field name="status"/>
        <field name="assignee_id"/>
        <field name="started_at"/>
        <field name="ended_at"/>
      </list>
    </field>
  </record>

  <record id="action_activity_instance" model="ir.actions.act_window">
    <field name="name">Activities</field>
    <field name="res_model">activity.instance</field>
    <field name="view_mode">list</field>
  </record>
</odoo>
