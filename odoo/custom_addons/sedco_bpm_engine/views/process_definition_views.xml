<odoo>
  <record id="view_bpm_process_definition_form" model="ir.ui.view">
    <field name="name">bpm.process.definition.form</field>
    <field name="model">bpm.process.definition</field>
    <field name="arch" type="xml">
      <form string="Process Definition">
        <sheet>
          <group>
            <field name="name"/>
            <field name="key"/>
            <field name="version"/>
            <field name="is_active"/>
            <button name="action_start_test" type="object" string="Start Test" class="oe_highlight"/>
          </group>
          <group>
            <field name="model_id"/>
            <field name="auto_apply"/>
            <field name="start_on_create_domain" placeholder="[]"/>
          </group>
          <notebook>
            <page string="BPMN Diagram">
              <group>
                <button name="action_open_bpmn_editor" type="object" string="Open BPMN Editor" class="oe_highlight"/>
                <field name="bpmn_xml" widget="text" nolabel="1" readonly="1"/>
              </group>
            </page>
            <page string="Definition (JSON)">
              <field name="definition_json" widget="text" nolabel="1" class="oe_inline"/>
            </page>
            <page string="Notes">
              <field name="note" widget="html"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_bpm_process_definition_list" model="ir.ui.view">
    <field name="name">bpm.process.definition.list</field>
    <field name="model">bpm.process.definition</field>
    <field name="arch" type="xml">
      <list string="Process Definitions">
        <field name="name"/>
        <field name="key"/>
        <field name="version"/>
        <field name="is_active"/>
        <field name="create_date"/>
      </list>
    </field>
  </record>

  <record id="action_bpm_process_definition" model="ir.actions.act_window">
    <field name="name">Process Definitions</field>
    <field name="res_model">bpm.process.definition</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
