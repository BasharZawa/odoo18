<odoo>
  <record id="view_process_definition_form" model="ir.ui.view">
    <field name="name">process.definition.form</field>
    <field name="model">process.definition</field>
    <field name="arch" type="xml">
      <form string="Process Definition">
        <sheet>
          <group>
            <field name="name"/>
            <field name="key"/>
            <field name="version"/>
            <field name="is_active"/>
            <field name="activity_count"/>
            <button name="action_start_test" type="object" string="Start Test" class="oe_highlight"/>
          </group>
          <group>
            <field name="model_id"/>
            <field name="auto_apply"/>
            <field name="start_on_create_domain" placeholder="[]"/>
          </group>
          <div class="oe_button_box" name="button_box">
            <button name="action_open_activities" type="object" class="oe_stat_button" icon="fa-tasks">
              <field name="activity_count" string="Activities" widget="statinfo"/>
            </button>
          </div>
          <notebook>
            <page string="Activities" name="activities">
              <group>
                <button name="action_generate_definition_from_activities" type="object" 
                        string="Generate JSON from Activities" class="btn-secondary"/>
                <button name="action_sync_activities_from_json" type="object" 
                        string="Sync Activities from JSON" class="btn-secondary"/>
              </group>
              <field name="activity_ids" context="{'default_definition_id': id}">
                <list editable="bottom" default_order="sequence">
                  <field name="sequence" widget="handle"/>
                  <field name="node_id"/>
                  <field name="name"/>
                  <field name="type"/>
                  <field name="next_activity_id" optional="hide"/>
                </list>
              </field>
            </page>
            <page string="BPMN Diagram">
              <group>
                <button name="action_open_bpmn_editor" type="object" string="Open BPMN Editor" class="oe_highlight"/>
                <field name="bpmn_xml" widget="text" nolabel="1" readonly="1"/>
              </group>
            </page>
            <page string="Definition (JSON)">
              <field name="definition_json" widget="text" nolabel="1" class="oe_inline"/>
            </page>
            <page string="Notes">
              <field name="note" widget="html"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_process_definition_list" model="ir.ui.view">
    <field name="name">process.definition.list</field>
    <field name="model">process.definition</field>
    <field name="arch" type="xml">
      <list string="Process Definitions">
        <field name="name"/>
        <field name="key"/>
        <field name="version"/>
        <field name="is_active"/>
        <field name="create_date"/>
      </list>
    </field>
  </record>

  <record id="action_process_definition" model="ir.actions.act_window">
    <field name="name">Process Definitions</field>
    <field name="res_model">process.definition</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
