<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- BPM Role Views -->
    
    <!-- list View -->
    <record id="view_bpm_role_list" model="ir.ui.view">
        <field name="name">bpm.role.list</field>
        <field name="model">bpm.role</field>
        <field name="arch" type="xml">
            <list string="BPM Roles">
                <field name="name"/>
                <field name="code"/>
                <field name="user_id"/>
                <field name="backup_user_id" optional="show"/>
                <field name="department_id" optional="hide"/>
                <field name="task_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bpm_role_form" model="ir.ui.view">
        <field name="name">bpm.role.form</field>
        <field name="model">bpm.role</field>
        <field name="arch" type="xml">
            <form string="BPM Role">
                <header>
                    <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_tasks" icon="fa-tasks">
                            <field string="Active Tasks" name="task_count" widget="statinfo"/>
                        </button>
                    </div>
                    <notebook>
                        <page string="General">
                            <group col="2">
                                <field name="name" required="1" placeholder="Role Name (e.g., Manager, Team Lead)"/>
                                <field name="code" required="1" placeholder="Role Code (e.g., MGR, TL)"/>
                                <field name="user_id" required="1"/>
                                <field name="backup_user_id"/>
                                <field name="department_id" optional="show"/>
                                <field name="company_id"/>
                            </group>
                            <field name="description" placeholder="Describe the responsibilities of this role..."/>
                        </page>
                        <page string="Configuration">
                            <group col="2">
                                <field name="escalation_timeout"/>
                                <field name="auto_assign"/>
                            </group>
                        </page>
                        <page string="Assignment History">
                            <field name="assignment_history_ids" readonly="1">
                                <list>
                                    <field name="change_date"/>
                                    <field name="old_user_id"/>
                                    <field name="new_user_id"/>
                                    <field name="change_reason"/>
                                    <field name="created_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
              
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bpm_role_search" model="ir.ui.view">
        <field name="name">bpm.role.search</field>
        <field name="model">bpm.role</field>
        <field name="arch" type="xml">
            <search string="BPM Roles">
                <field name="name"/>
                <field name="code"/>
                <field name="user_id"/>
                <field name="department_id"/>
                
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Has Active Tasks" name="has_tasks" domain="[('task_count', '>', 0)]"/>
                <filter string="No Backup User" name="no_backup" domain="[('backup_user_id', '=', False)]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Assigned User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bpm_role" model="ir.actions.act_window">
        <field name="name">BPM Roles</field>
        <field name="res_model">bpm.role</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bpm_role_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first BPM role!
            </p>
            <p>
                BPM roles provide a flexible way to assign process activities to specific 
                organizational roles rather than individual users. When staff changes occur, 
                simply reassign the role to the new person without updating every process.
            </p>
        </field>
    </record>

    <!-- Assignment History Views -->
    <record id="view_bpm_role_assignment_history_list" model="ir.ui.view">
        <field name="name">bpm.role.assignment.history.list</field>
        <field name="model">bpm.role.assignment.history</field>
        <field name="arch" type="xml">
            <list string="Role Assignment History" create="false" edit="false" delete="false">
                <field name="change_date"/>
                <field name="role_id"/>
                <field name="old_user_id"/>
                <field name="new_user_id"/>
                <field name="change_reason"/>
                <field name="created_by"/>
            </list>
        </field>
    </record>

    <record id="action_bpm_role_assignment_history" model="ir.actions.act_window">
        <field name="name">Role Assignment History</field>
        <field name="res_model">bpm.role.assignment.history</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_bpm_role_assignment_history_list"/>
    </record>

</odoo>
