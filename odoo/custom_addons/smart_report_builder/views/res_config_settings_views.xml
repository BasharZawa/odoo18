<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_smart_report" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.smart.report</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Smart Report Builder"
                     string="Smart Report Builder"
                     groups="base.group_system">
                    <block title="AI Configuration">
                        <setting title="n8n Webhook"
                                 help="Configure the n8n webhook endpoint that connects to Claude AI">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="smart_report_n8n_webhook_url"
                                           class="col-lg-3 o_light_label"/>
                                    <field name="smart_report_n8n_webhook_url"
                                           placeholder="https://your-n8n.hetzner.com/webhook/smart-report"/>
                                </div>
                                <div class="row mt8">
                                    <label for="smart_report_n8n_auth_token"
                                           class="col-lg-3 o_light_label"/>
                                    <field name="smart_report_n8n_auth_token"
                                           password="True"
                                           placeholder="Optional: Bearer token for webhook security"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
