<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client Action: launches the OWL component -->
    <record id="action_smart_report_builder" model="ir.actions.client">
        <field name="name">Smart Report Builder</field>
        <field name="tag">smart_report_builder</field>
        <field name="target">main</field>
    </record>

    <!-- Tree view for saved reports -->
    <record id="view_smart_report_tree" model="ir.ui.view">
        <field name="name">smart.report.tree</field>
        <field name="model">smart.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="natural_query"/>
                <field name="model_name"/>
                <field name="chart_type"/>
                <field name="is_favorite" widget="boolean_favorite"/>
                <field name="user_id"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>

    <!-- Form view for saved reports -->
    <record id="view_smart_report_form" model="ir.ui.view">
        <field name="name">smart.report.form</field>
        <field name="model">smart.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_report" type="object"
                            string="Run Report" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_name"/>
                            <field name="chart_type"/>
                            <field name="is_favorite"/>
                        </group>
                        <group>
                            <field name="natural_query"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Query Details">
                            <group>
                                <field name="domain"/>
                                <field name="group_by"/>
                                <field name="measures"/>
                            </group>
                        </page>
                        <page string="Last Result">
                            <field name="last_result"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for saved reports list -->
    <record id="action_smart_report_saved" model="ir.actions.act_window">
        <field name="name">Saved Reports</field>
        <field name="res_model">smart.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_smart_report_root"
              name="Smart Reports"
              web_icon="smart_report_builder,static/description/icon.png"
              sequence="90"/>

    <!-- Sub menus -->
    <menuitem id="menu_smart_report_builder"
              name="Report Builder"
              parent="menu_smart_report_root"
              action="action_smart_report_builder"
              sequence="10"/>

    <menuitem id="menu_smart_report_saved"
              name="Saved Reports"
              parent="menu_smart_report_root"
              action="action_smart_report_saved"
              sequence="20"/>

</odoo>
