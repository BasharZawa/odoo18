<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="approval_request_view_form_inherit_discount" model="ir.ui.view">
        <field name="name">approval.request.view.form.inherit.discount</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_disc_req" invisible="1"/>
                <field name="parent_request_id" invisible="not is_disc_req" readonly="1"/>
            </xpath>
            <xpath expr="//page[@name='products']" position="after">
                <page string="Child Requests" invisible="not is_disc_req">
                    <field name="child_request_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="request_owner_id"/>
                            <field name="request_status"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
