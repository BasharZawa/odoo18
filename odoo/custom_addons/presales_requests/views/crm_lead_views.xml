<odoo>
  <record id="crm_lead_view_form_inherit_presales" model="ir.ui.view">
    <field name="name">crm.lead.form.inherit.presales</field>
    <field name="model">crm.lead</field>
    <field name="inherit_id" ref="crm.crm_lead_view_form"/>
    <field name="arch" type="xml">
      <notebook position="inside">
        <page string="Presales Requests">
          <field name="presales_request_ids">
            <list>
              <field name="name"/>
              <field name="state"/>
              <field name="assigned_to"/>
              <field name="deadline"/>
            </list>
          </field>
        </page>
      </notebook>
    </field>
  </record>
</odoo>