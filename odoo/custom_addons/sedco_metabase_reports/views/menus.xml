<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- URL actions (one per dashboard) -->
    <record id="action_reports_index" model="ir.actions.act_url">
        <field name="name">Reports</field>
        <field name="url">/metabase/reports</field>
        <field name="target">self</field>
    </record>

    <record id="action_embed_sales_orders" model="ir.actions.act_url">
        <field name="name">Sales Orders</field>
        <field name="url">/metabase/embed/sales_orders</field>
        <field name="target">self</field>
    </record>

    <record id="action_embed_accounts" model="ir.actions.act_url">
        <field name="name">Accounts</field>
        <field name="url">/metabase/embed/accounts</field>
        <field name="target">self</field>
    </record>

    <record id="action_embed_contacts" model="ir.actions.act_url">
        <field name="name">Contacts</field>
        <field name="url">/metabase/embed/contacts</field>
        <field name="target">self</field>
    </record>

    <record id="action_embed_migration_kpis" model="ir.actions.act_url">
        <field name="name">Migration KPIs</field>
        <field name="url">/metabase/embed/migration_kpis</field>
        <field name="target">self</field>
    </record>

    <record id="action_embed_sync_health" model="ir.actions.act_url">
        <field name="name">Sync Health</field>
        <field name="url">/metabase/embed/sync_health</field>
        <field name="target">self</field>
    </record>

    <!-- Top-level Reports menu (visible to anyone in a Metabase group) -->
    <menuitem id="menu_reports_root"
              name="Reports"
              action="action_reports_index"
              sequence="85"
              groups="group_mb_viewer,group_mb_manager,group_mb_ops"
              web_icon="sedco_metabase_reports,static/description/icon.png"/>

    <menuitem id="menu_reports_sales_orders"
              parent="menu_reports_root"
              name="Sales Orders"
              action="action_embed_sales_orders"
              sequence="10"
              groups="group_mb_viewer,group_mb_manager"/>

    <menuitem id="menu_reports_accounts"
              parent="menu_reports_root"
              name="Accounts"
              action="action_embed_accounts"
              sequence="20"
              groups="group_mb_viewer,group_mb_manager"/>

    <menuitem id="menu_reports_contacts"
              parent="menu_reports_root"
              name="Contacts"
              action="action_embed_contacts"
              sequence="30"
              groups="group_mb_viewer,group_mb_manager"/>

    <menuitem id="menu_reports_migration_kpis"
              parent="menu_reports_root"
              name="Migration KPIs"
              action="action_embed_migration_kpis"
              sequence="40"
              groups="group_mb_manager,group_mb_ops"/>

    <menuitem id="menu_reports_sync_health"
              parent="menu_reports_root"
              name="Sync Health"
              action="action_embed_sync_health"
              sequence="50"
              groups="group_mb_ops"/>

    <!-- Admin configuration menu (managers only) -->
    <menuitem id="menu_reports_config"
              parent="menu_reports_root"
              name="Configuration"
              sequence="100"
              groups="group_mb_manager"/>

    <menuitem id="menu_metabase_dashboard_config"
              parent="menu_reports_config"
              name="Metabase Dashboards"
              action="action_metabase_dashboard"
              sequence="10"
              groups="group_mb_manager"/>

    <menuitem id="menu_metabase_sync_schedule_config"
              parent="menu_reports_config"
              name="Scheduled Sync Jobs"
              action="action_metabase_sync_schedule"
              sequence="20"
              groups="group_mb_manager"/>

</odoo>
