<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        noupdate="1" prevents module upgrades from resetting operator edits.
        Add new models here as OdooSyncConfig.MODELS grows.
        The 'name' field must match a key in OdooSyncConfig.MODELS exactly.
    -->

    <!-- Core transactional models -->
    <record id="sync_model_sale_order" model="metabase.sync.model">
        <field name="name">sale.order</field>
        <field name="display">Sales Orders</field>
    </record>
    <record id="sync_model_sale_order_line" model="metabase.sync.model">
        <field name="name">sale.order.line</field>
        <field name="display">Sales Order Lines</field>
    </record>
    <record id="sync_model_crm_lead" model="metabase.sync.model">
        <field name="name">crm.lead</field>
        <field name="display">CRM Leads / Opportunities</field>
    </record>
    <record id="sync_model_account_move" model="metabase.sync.model">
        <field name="name">account.move</field>
        <field name="display">Invoices / Bills</field>
    </record>
    <record id="sync_model_account_move_line" model="metabase.sync.model">
        <field name="name">account.move.line</field>
        <field name="display">Invoice Lines</field>
    </record>

    <!-- Master data: partners -->
    <record id="sync_model_res_partner" model="metabase.sync.model">
        <field name="name">res.partner</field>
        <field name="display">Partners (Contacts &amp; Accounts)</field>
    </record>
    <record id="sync_model_res_partner_category" model="metabase.sync.model">
        <field name="name">res.partner.category</field>
        <field name="display">Partner Tags / Categories</field>
    </record>

    <!-- Master data: products -->
    <record id="sync_model_product_template" model="metabase.sync.model">
        <field name="name">product.template</field>
        <field name="display">Product Templates</field>
    </record>
    <record id="sync_model_product_product" model="metabase.sync.model">
        <field name="name">product.product</field>
        <field name="display">Product Variants</field>
    </record>
    <record id="sync_model_product_category" model="metabase.sync.model">
        <field name="name">product.category</field>
        <field name="display">Product Categories</field>
    </record>

    <!-- Master data: users / company -->
    <record id="sync_model_res_users" model="metabase.sync.model">
        <field name="name">res.users</field>
        <field name="display">Users</field>
    </record>
    <record id="sync_model_res_company" model="metabase.sync.model">
        <field name="name">res.company</field>
        <field name="display">Companies</field>
    </record>
    <record id="sync_model_res_currency" model="metabase.sync.model">
        <field name="name">res.currency</field>
        <field name="display">Currencies</field>
    </record>
    <record id="sync_model_res_country" model="metabase.sync.model">
        <field name="name">res.country</field>
        <field name="display">Countries</field>
    </record>

    <!-- Stage E: M2O lookup models -->
    <record id="sync_model_crm_team" model="metabase.sync.model">
        <field name="name">crm.team</field>
        <field name="display">Sales Teams</field>
    </record>
    <record id="sync_model_crm_stage" model="metabase.sync.model">
        <field name="name">crm.stage</field>
        <field name="display">CRM Stages</field>
    </record>
    <record id="sync_model_crm_tag" model="metabase.sync.model">
        <field name="name">crm.tag</field>
        <field name="display">CRM / Order Tags</field>
    </record>
    <record id="sync_model_hr_department" model="metabase.sync.model">
        <field name="name">hr.department</field>
        <field name="display">HR Departments</field>
    </record>
    <record id="sync_model_hr_employee" model="metabase.sync.model">
        <field name="name">hr.employee</field>
        <field name="display">Employees</field>
    </record>

</odoo>
