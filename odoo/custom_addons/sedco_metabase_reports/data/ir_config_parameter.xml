<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Seeds ONLY the site_url placeholder. All other params are deliberately NOT
        seeded — a dummy value would silently pass the controller's checks and produce
        broken embeds or expose the sync endpoint. The controller fast-fails (403) or
        skips sync gracefully when these are missing/empty.

        Set ALL values after install via:
          Settings → Technical → Parameters → System Parameters
        or `odoo-bin shell`:
          ir_config.set_param('sedco_metabase_reports.site_url', 'http://...')
          ir_config.set_param('sedco_metabase_reports.jwt_secret', '<hex>')
          # Stage E — on-demand sync (leave unset to disable on-demand sync):
          ir_config.set_param('sedco_metabase_reports.uxserver_url', 'https://uxserver.sedco.co')
          ir_config.set_param('sedco_metabase_reports.uxserver_sync_api_key', '<UXSERVER_SYNC_API_KEY value>')
    -->

    <record id="config_site_url" model="ir.config_parameter">
        <field name="key">sedco_metabase_reports.site_url</field>
        <field name="value">http://localhost:3000</field>
    </record>

</odoo>
