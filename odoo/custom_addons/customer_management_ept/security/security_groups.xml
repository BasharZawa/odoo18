<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category for Customer Management -->
        <record id="module_category_customer_management" model="ir.module.category">
            <field name="name">Customer Management</field>
            <field name="sequence">15</field>
            <field name="parent_id" ref="base.module_category_human_resources"/>
        </record>

        <!-- Finance Team Group -->
        <record id="group_finance_team" model="res.groups">
            <field name="name">Finance Team</field>
            <field name="category_id" ref="customer_management_ept.module_category_customer_management"/>
            <field name="comment">Users who can validate customer contacts and have special access to validated customer
                data.
            </field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Sales Team Group -->
        <record id="group_sales_team" model="res.groups">
            <field name="name">Sales Team</field>
            <field name="category_id" ref="customer_management_ept.module_category_customer_management"/>
            <field name="comment">Users who can create and manage sales orders and schedules.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Sales Manager Group -->
        <record id="group_sales_manager" model="res.groups">
            <field name="name">Sales Manager</field>
            <field name="category_id" ref="customer_management_ept.module_category_customer_management"/>
            <field name="comment">Users who can approve sales orders and manage all sales operations.</field>
            <field name="implied_ids" eval="[(4, ref('customer_management_ept.group_sales_team'))]"/>
        </record>

    </data>
</odoo>
