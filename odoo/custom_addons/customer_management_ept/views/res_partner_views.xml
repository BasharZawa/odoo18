<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- Partner Form View -->
        <record id="view_partner_form_customer_validation" model="ir.ui.view">
            <field name="name">res.partner.form.customer.validation</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <!-- Add Customer ID field after VAT -->
<!--                <field name="vat" position="after">-->
<!--                    <field name="customer_id" readonly="1"/>-->
<!--                </field>-->
                <xpath expr="//field[@name='vat']/../.." position="inside">
                    <field name="customer_id" readonly="1"/>
                </xpath>
                <xpath expr="//div[@name='warning_tax']" position="before">
                    <header>
                        <field name="validation_status" widget="statusbar" statusbar_visible="not_validated,validated"
                               class="oe_highlight"/>
                        <button name="action_validate_customer"
                                type="object"
                                class="btn-primary"
                                string="Validate Customer"
                                icon="fa-check"
                                context="{'check_bypass': True}"
                                invisible="validation_status == 'validated'"/>
                        <button name="action_invalidate_customer"
                                type="object"
                                class="btn-secondary"
                                string="Invalidate Customer"
                                icon="fa-times"
                                context="{'check_bypass': True}"
                                invisible="validation_status != 'validated'"/>
                    </header>
                </xpath>


                <!-- Add validation section -->
                <xpath expr="//page[@name='sales_purchases']" position="after">
                    <page string="Customer Validation">

                        <!-- Validation warning for non-finance users -->
                        <div class="alert alert-warning" role="alert"
                             invisible="validation_status != 'validated'">
                            <strong>Note:</strong>
                            This customer is validated. Only Finance team members can edit validated customer data.
                        </div>

                        <!-- Validation pending warning -->
                        <div class="alert alert-info" role="status"
                             invisible="validation_status != 'not_validated'">
                            <strong>Validation Required:</strong>
                            This customer requires validation by the Finance team before sales orders can be confirmed.
                        </div>
                        <group>
                            <field name="validated_by" readonly="1"/>
                            <field name="validation_date" readonly="1"/>
                            <field name="validation_notes" readonly="validation_status == 'validated'"/>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>
</odoo>
