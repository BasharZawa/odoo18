<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Sale Order Form View -->
        <record id="view_sale_order_form_customer_validation" model="ir.ui.view">
            <field name="name">sale.order.form.customer.validation</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <!-- Add End Customer field after partner_id -->
                <field name="partner_id" position="after">
                    <field name="end_customer_id" options="{'no_create': True, 'no_open': True}"/>
                </field>

                <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                    <field name="special_price_flag"/>
                </xpath>

                <!-- Modify the confirm button to hide when validation is pending -->
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="invisible">
                        state in ['sale', 'done', 'cancel'] or partner_id.validation_status != 'validated'
                    </attribute>
                </xpath>

                <!-- Add schedule tabs after order lines -->
                <xpath expr="//notebook" position="inside">

                    <!-- Invoicing Schedule Tab -->
                    <page string="Invoicing Schedule" name="invoicing_schedule">
                        <group>
                            <field name="total_invoicing_amount" class="oe_subtotal_footer_separator"/>
                        </group>
                        <field name="invoicing_schedule_ids">
                            <list editable="bottom">
                                <field name="invoice_date"/>
                                <field name="due_date"/>
                                <field name="billing_milestone_description"/>
                                <field name="invoice_amount"/>
                                <field name="invoiced_status"/>
                                <field name="reference_document"/>
                            </list>
                        </field>
                    </page>

                    <!-- Recognition Schedule Tab -->
                    <page string="Recognition Schedule" name="recognition_schedule">
                        <group>
                            <field name="total_recognition_amount" class="oe_subtotal_footer_separator"/>

                        </group>
                        <field name="recognition_schedule_ids">
                            <list editable="bottom">
                                <field name="recognition_date"/>
                                <field name="description"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </page>

                    <!-- Distribution Schedule Tab -->
                    <page string="Distribution Schedule" name="distribution_schedule">
                        <group>
                            <field name="total_commission_percentage" class="oe_subtotal_footer_separator"/>
                        </group>
                        <field name="distribution_schedule_ids">
                            <list editable="bottom">
                                <field name="salesperson_id"/>
                                <field name="commission_percentage"/>
                                <field name="commission_amount" readonly="1"/>
                            </list>
                        </field>
                    </page>

                </xpath>

            </field>
        </record>

        <!-- Invoicing Schedule Tree View -->
        <record id="view_sale_order_invoicing_schedule_tree" model="ir.ui.view">
            <field name="name">sale.order.invoicing.schedule.tree</field>
            <field name="model">sale.order.invoicing.schedule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sale_order_id"/>
                    <field name="invoice_date"/>
                    <field name="due_date"/>
                    <field name="billing_milestone_description"/>
                    <field name="invoice_amount"/>
                    <field name="invoiced_status"/>
                    <field name="reference_document"/>
                </list>
            </field>
        </record>

        <!-- Recognition Schedule Tree View -->
        <record id="view_sale_order_recognition_schedule_tree" model="ir.ui.view">
            <field name="name">sale.order.recognition.schedule.tree</field>
            <field name="model">sale.order.recognition.schedule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sale_order_id"/>
                    <field name="recognition_date"/>
                    <field name="description"/>
                    <field name="amount"/>
                </list>
            </field>
        </record>

        <!-- Distribution Schedule Tree View -->
        <record id="view_sale_order_distribution_schedule_tree" model="ir.ui.view">
            <field name="name">sale.order.distribution.schedule.tree</field>
            <field name="model">sale.order.distribution.schedule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sale_order_id"/>
                    <field name="salesperson_id"/>
                    <field name="commission_percentage"/>
                    <field name="commission_amount"/>
                </list>
            </field>
        </record>

    </data>
</odoo>
