<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_cost_tree_view_restrict" model="ir.ui.view">
        <field name="name">product.product.cost.tree.view.restrict</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_product_cost_form_view_restrict" model="ir.ui.view">
        <field name="name">product.product.cost.form.view.restrict</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_cost_tree_view_restrict" model="ir.ui.view">
        <field name="name">product.template.cost.tree.view.restrict</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_cost_form_view_restrict" model="ir.ui.view">
        <field name="name">product.template.cost.form.view.restrict</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="groups">sale_extended_ept.group_view_product_cost</attribute>
            </xpath>
        </field>
    </record>
</odoo>
