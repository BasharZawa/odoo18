<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Task Instance Views -->
        <record id="view_bmp_task_instance_list" model="ir.ui.view">
            <field name="name">bmp.task.instance.list</field>
            <field name="model">bmp.task.instance</field>
            <field name="arch" type="xml">
                <list string="Task Instances">
                    <field name="task_name"/>
                    <field name="process_instance_id"/>
                    <field name="task_type"/>
                    <field name="status" decoration-info="status=='ready'" 
                           decoration-warning="status in ['claimed','in_progress']" 
                           decoration-success="status=='completed'" 
                           decoration-danger="status=='failed'"/>
                    <field name="assigned_user_id"/>
                    <field name="claimed_by_id"/>
                    <field name="priority"/>
                    <field name="due_date"/>
                    <field name="is_overdue" widget="boolean"/>
                    <field name="created_at"/>
                    <field name="duration"/>
                </list>
            </field>
        </record>
        
        <record id="view_bmp_task_instance_form" model="ir.ui.view">
            <field name="name">bmp.task.instance.form</field>
            <field name="model">bmp.task.instance</field>
            <field name="arch" type="xml">
                <form string="Task Instance">
                    <header>
                        <button name="action_claim" string="Claim" type="object" class="btn-primary" 
                                invisible="not can_claim or status != 'ready'"/>
                        <button name="action_start" string="Start" type="object" class="btn-primary" 
                                invisible="status not in ['claimed', 'ready']"/>
                        <button name="action_complete" string="Complete" type="object" class="btn-success" 
                                invisible="not can_complete or status not in ['claimed', 'in_progress']"/>
                        <button name="action_skip" string="Skip" type="object" 
                                invisible="status not in ['ready', 'claimed', 'in_progress']"/>
                        <field name="status" widget="statusbar" statusbar_visible="ready,claimed,in_progress,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="task_name" readonly="1"/></h1>
                        </div>
                        
                        <div class="alert alert-warning" role="alert" invisible="not is_overdue">
                            <strong>Warning!</strong> This task is overdue.
                        </div>
                        
                        <group>
                            <group>
                                <field name="process_instance_id"/>
                                <field name="task_type"/>
                                <field name="task_id" readonly="1"/>
                                <field name="priority"/>
                            </group>
                            <group>
                                <field name="assigned_user_id"/>
                                <field name="assigned_group_id"/>
                                <field name="claimed_by_id" readonly="1"/>
                                <field name="due_date"/>
                                <field name="is_overdue" readonly="1"/>
                            </group>
                        </group>
                        
                        <group>
                            <group>
                                <field name="created_at" readonly="1"/>
                                <field name="started_at" readonly="1"/>
                                <field name="completed_at" readonly="1"/>
                                <field name="duration" readonly="1"/>
                            </group>
                            <group>
                                <field name="retry_count" readonly="1"/>
                                <field name="max_retries"/>
                                <field name="can_claim" readonly="1"/>
                                <field name="can_complete" readonly="1"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Form Data" invisible="task_type not in ['user', 'manual']">
                                <field name="form_data" widget="ace" options="{'mode': 'json'}"/>
                            </page>
                            <page string="Script" invisible="task_type != 'script'">
                                <field name="script_code" widget="ace" options="{'mode': 'python'}"/>
                            </page>
                            <page string="Service Configuration" invisible="task_type != 'service'">
                                <group>
                                    <field name="service_class"/>
                                    <field name="service_method"/>
                                </group>
                            </page>
                            <page string="Task Data">
                                <field name="task_data" widget="ace" options="{'mode': 'json'}"/>
                            </page>
                            <page string="Output Data">
                                <field name="output_data" widget="ace" options="{'mode': 'json'}"/>
                            </page>
                            <page string="Variables">
                                <field name="task_variables" readonly="1">
                                    <list>
                                        <field name="key"/>
                                        <field name="type"/>
                                        <field name="display_value"/>
                                        <field name="scope"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Activity Log">
                                <field name="activity_logs" readonly="1">
                                    <list>
                                        <field name="timestamp"/>
                                        <field name="action_type"/>
                                        <field name="actor_id"/>
                                        <field name="details"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Error Details" invisible="status != 'failed'">
                                <field name="error_message" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_bmp_task_instance_search" model="ir.ui.view">
            <field name="name">bmp.task.instance.search</field>
            <field name="model">bmp.task.instance</field>
            <field name="arch" type="xml">
                <search>
                    <field name="task_name"/>
                    <field name="process_instance_id"/>
                    <field name="assigned_user_id"/>
                    <field name="claimed_by_id"/>
                    <filter string="My Tasks" name="my_tasks" 
                            domain="['|', ('assigned_user_id', '=', uid), ('claimed_by_id', '=', uid)]"/>
                    <filter string="Available Tasks" name="available_tasks" 
                            domain="[('status', '=', 'ready'), '|', ('assigned_user_id', '=', False), ('assigned_user_id', '=', uid)]"/>
                    <filter string="Ready" name="ready" domain="[('status', '=', 'ready')]"/>
                    <filter string="In Progress" name="in_progress" domain="[('status', 'in', ['claimed', 'in_progress'])]"/>
                    <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                    <filter string="Failed" name="failed" domain="[('status', '=', 'failed')]"/>
                    <filter string="User Tasks" name="user_tasks" domain="[('task_type', '=', 'user')]"/>
                    <filter string="Service Tasks" name="service_tasks" domain="[('task_type', '=', 'service')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" domain="[]" context="{'group_by': 'status'}"/>
                        <filter string="Task Type" name="group_task_type" domain="[]" context="{'group_by': 'task_type'}"/>
                        <filter string="Process" name="group_process" domain="[]" context="{'group_by': 'process_instance_id'}"/>
                        <filter string="Assigned User" name="group_assigned" domain="[]" context="{'group_by': 'assigned_user_id'}"/>
                        <filter string="Priority" name="group_priority" domain="[]" context="{'group_by': 'priority'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Kanban View for My Tasks Dashboard -->
        <record id="view_bmp_task_instance_kanban" model="ir.ui.view">
            <field name="name">bmp.task.instance.kanban</field>
            <field name="model">bmp.task.instance</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_dashboard">
                    <field name="task_name"/>
                    <field name="process_instance_id"/>
                    <field name="priority"/>
                    <field name="due_date"/>
                    <field name="is_overdue"/>
                    <field name="assigned_user_id"/>
                    <field name="can_claim"/>
                    <field name="can_complete"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="task_name"/>
                                            </strong>
                                            <div class="o_kanban_record_subtitle text-muted">
                                                <field name="process_instance_id"/>
                                            </div>
                                        </div>
                                        <div class="o_dropdown_kanban dropdown">
                                            <a class="dropdown-toggle o-no-caret btn" data-toggle="dropdown" href="#" role="button" aria-label="Dropdown menu" title="Dropdown menu">
                                                <span class="fa fa-ellipsis-v"/>
                                            </a>
                                            <div class="dropdown-menu" role="menu">
                                                <a t-if="record.can_claim.raw_value and record.status.raw_value == 'ready'" type="object" name="action_claim" class="dropdown-item">Claim</a>
                                                <a t-if="record.status.raw_value in ['claimed', 'ready']" type="object" name="action_start" class="dropdown-item">Start</a>
                                                <a t-if="record.can_complete.raw_value" type="object" name="action_complete" class="dropdown-item">Complete</a>
                                                <a type="object" name="action_skip" class="dropdown-item">Skip</a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <div t-if="record.due_date.raw_value" class="text-muted">
                                            <i class="fa fa-clock-o"/> Due: <field name="due_date"/>
                                        </div>
                                        <div t-if="record.assigned_user_id.raw_value" class="text-muted">
                                            <i class="fa fa-user"/> <field name="assigned_user_id"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <span t-if="record.priority.raw_value == 'high'" class="badge badge-warning">High</span>
                                            <span t-if="record.priority.raw_value == 'urgent'" class="badge badge-danger">Urgent</span>
                                            <span t-if="record.is_overdue.raw_value" class="badge badge-danger">Overdue</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_bmp_task_instance" model="ir.actions.act_window">
            <field name="name">All Tasks</field>
            <field name="res_model">bmp.task.instance</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="search_view_id" ref="view_bmp_task_instance_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No tasks found!
                </p>
                <p>
                    Tasks are created when process instances reach user tasks or service tasks.
                    They represent work items that need to be completed to advance the process.
                </p>
            </field>
        </record>
        
        <record id="action_bmp_task_instance_my_tasks" model="ir.actions.act_window">
            <field name="name">My Tasks</field>
            <field name="res_model">bmp.task.instance</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_bmp_task_instance_search"/>
            <field name="context">{'search_default_my_tasks': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    You have no tasks assigned!
                </p>
                <p>
                    This view shows tasks that are assigned to you or claimed by you.
                    Use the filters to find available tasks you can claim.
                </p>
            </field>
        </record>
        
    </data>
</odoo>