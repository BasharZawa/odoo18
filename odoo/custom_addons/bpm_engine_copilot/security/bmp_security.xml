<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Security Groups -->
        <record id="group_bmp_user" model="res.groups">
            <field name="name">BPMN User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Basic BPMN user - can view and execute processes</field>
        </record>
        
        <record id="group_bmp_manager" model="res.groups">
            <field name="name">BPMN Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="comment">BPMN manager - can create and manage processes</field>
        </record>
        
        <record id="group_bmp_admin" model="res.groups">
            <field name="name">BPMN Administrator</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="comment">BPMN administrator - full access to all BPMN features</field>
        </record>
        
        <!-- Security Rules -->
        <record id="rule_bmp_process_definition_read" model="ir.rule">
            <field name="name">Process Definition: Read Access</field>
            <field name="model_id" ref="model_bmp_process_definition"/>
            <field name="domain_force">['|', ('is_active', '=', True), ('created_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="rule_bmp_process_definition_write" model="ir.rule">
            <field name="name">Process Definition: Write Access</field>
            <field name="model_id" ref="model_bmp_process_definition"/>
            <field name="domain_force">['|', ('created_by', '=', user.id), ('id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_process_instance_user" model="ir.rule">
            <field name="name">Process Instance: User Access</field>
            <field name="model_id" ref="model_bmp_process_instance"/>
            <field name="domain_force">['|', ('created_by', '=', user.id), ('assigned_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="rule_bmp_process_instance_manager" model="ir.rule">
            <field name="name">Process Instance: Manager Access</field>
            <field name="model_id" ref="model_bmp_process_instance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_task_instance_user" model="ir.rule">
            <field name="name">Task Instance: User Access</field>
            <field name="model_id" ref="model_bmp_task_instance"/>
            <field name="domain_force">['|', '|', ('assigned_user_id', '=', user.id), ('claimed_by_id', '=', user.id), ('assigned_group_id', 'in', [g.id for g in user.groups_id])]</field>
            <field name="groups" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="rule_bmp_task_instance_manager" model="ir.rule">
            <field name="name">Task Instance: Manager Access</field>
            <field name="model_id" ref="model_bmp_task_instance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_activity_log_read" model="ir.rule">
            <field name="name">Activity Log: Read Access</field>
            <field name="model_id" ref="model_bmp_activity_log"/>
            <field name="domain_force">['|', ('actor_id', '=', user.id), ('process_instance_id.created_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="rule_bmp_activity_log_manager" model="ir.rule">
            <field name="name">Activity Log: Manager Access</field>
            <field name="model_id" ref="model_bmp_activity_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_process_variable_user" model="ir.rule">
            <field name="name">Process Variable: User Access</field>
            <field name="model_id" ref="model_bmp_process_variable"/>
            <field name="domain_force">[('process_instance_id.created_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <record id="rule_bmp_process_variable_manager" model="ir.rule">
            <field name="name">Process Variable: Manager Access</field>
            <field name="model_id" ref="model_bmp_process_variable"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_sla_rule_manager" model="ir.rule">
            <field name="name">SLA Rule: Manager Access</field>
            <field name="model_id" ref="model_bmp_sla_rule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
        <record id="rule_bmp_integration_manager" model="ir.rule">
            <field name="name">Integration: Manager Access</field>
            <field name="model_id" ref="model_bmp_integration"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bmp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
    </data>
</odoo>