<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Task Complete Wizard Views -->
        <record id="view_bmp_task_complete_form" model="ir.ui.view">
            <field name="name">bmp.task.complete.form</field>
            <field name="model">bmp.task.complete</field>
            <field name="arch" type="xml">
                <form string="Complete Task">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="task_name" readonly="1"/></h1>
                            <h2><field name="process_instance_id" readonly="1"/></h2>
                        </div>
                        
                        <group string="Task Completion">
                            <field name="task_instance_id" invisible="1"/>
                            <field name="completion_comment" placeholder="Add a comment about your work..."/>
                        </group>
                        
                        <group string="Output Data">
                            <field name="output_data" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_complete_task" string="Complete Task" type="object" class="btn-primary"/>
                        <button name="action_save_and_continue" string="Save Progress" type="object" class="btn-secondary"/>
                        <button name="action_preview_output" string="Preview Output" type="object" class="btn-secondary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Task Complete Wizard Action -->
        <record id="action_bmp_task_complete" model="ir.actions.act_window">
            <field name="name">Complete Task</field>
            <field name="res_model">bmp.task.complete</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_bmp_task_complete_form"/>
            <field name="target">new</field>
        </record>
        
    </data>
</odoo>