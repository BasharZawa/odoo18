<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Create a new list view instead of inheriting -->
  <record id="view_crm_lead_sedco_list" model="ir.ui.view">
    <field name="name">crm.lead.list.sedco</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
      <list string="Leads &amp; Opportunities">
        <field name="name"/>
        <field name="partner_name"/>
        <field name="email_from"/>
        <field name="phone"/>
        <field name="stage_id"/>
        <field name="product_category_id"/>
        <field name="is_service"/>
        <field name="forwarded_partner_id"/>
        <field name="postponed_until"/>
        <field name="disqual_reason"/>
        <field name="user_id"/>
        <field name="date_deadline"/>
        <field name="expected_revenue"/>
        <field name="create_date"/>
      </list>
    </field>
  </record>

  <!-- Create a new form view instead of inheriting -->
  <record id="view_crm_lead_sedco_form" model="ir.ui.view">
    <field name="name">crm.lead.form.sedco</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
      <form string="Lead">
        <sheet>
          <group>
            <group string="Lead Information">
              <field name="name"/>
              <field name="partner_name"/>
              <field name="email_from"/>
              <field name="phone"/>
              <field name="stage_id"/>
              <field name="user_id"/>
            </group>
            
            <group string="Lead Classification">
              <field name="product_category_id"/>
              <field name="is_service"/>
              <field name="origin_type"/>
              <field name="campaign_id"/>
              <field name="medium_id"/>
              <field name="source_id"/>
            </group>
          </group>

          <group string="Partner Handoff &amp; Scheduling">
            <field name="forwarded_partner_id"/>
            <field name="postponed_until"/>
            <button name="action_forward_to_partner" type="object" string="Mark as Forwarded to Partner"
                    class="btn-secondary" invisible="not forwarded_partner_id"/>
          </group>

          <group string="Disqualification">
            <field name="disqual_reason"/>
            <field name="disqual_comment"/>
          </group>

          <notebook>
            <page string="Stage Log">
              <field name="stage_log_ids" context="{'default_lead_id': id}">
                <list create="0" edit="0">
                  <field name="changed_on"/>
                  <field name="changed_by"/>
                  <field name="stage_id"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
</odoo> 
