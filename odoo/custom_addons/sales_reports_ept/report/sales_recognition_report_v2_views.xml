<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== SALES RECOGNITION REPORT V2 (Simplified) ==================== -->
    
    <!-- Enhanced Pivot View with Monthly Columns -->
    <record id="sales_recognition_report_v2_pivot" model="ir.ui.view">
        <field name="name">sale.order.recognition.schedule.pivot.v2</field>
        <field name="model">sale.order.recognition.schedule</field>
        <field name="arch" type="xml">
            <pivot string="Sales Recognition V2" sample="1">
                <field name="sale_order_id" type="row"/>
                <field name="recognition_date" interval="month" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>
    
    <!-- Enhanced Graph View -->
    <record id="sales_recognition_report_v2_graph" model="ir.ui.view">
        <field name="name">sale.order.recognition.schedule.graph.v2</field>
        <field name="model">sale.order.recognition.schedule</field>
        <field name="arch" type="xml">
            <graph string="Sales Recognition V2" type="bar" stacked="1" sample="1">
                <field name="recognition_date" interval="month"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>
    
    <!-- Enhanced List View -->
    <record id="sales_recognition_report_v2_list" model="ir.ui.view">
        <field name="name">sale.order.recognition.schedule.list.v2</field>
        <field name="model">sale.order.recognition.schedule</field>
        <field name="arch" type="xml">
            <list string="Sales Recognition V2" default_order="recognition_date" 
                  decoration-info="recognition_date &gt; context_today()"
                  decoration-muted="recognition_date &lt; context_today().replace(day=1)">
                <field name="sale_order_id" decoration-bf="1"/>
                <field name="recognition_date" widget="date"/>
                <field name="description"/>
                <field name="amount" sum="Total Amount" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    
    <!-- Enhanced Search View with Filters -->
    <record id="sales_recognition_report_v2_search" model="ir.ui.view">
        <field name="name">sale.order.recognition.schedule.search.v2</field>
        <field name="model">sale.order.recognition.schedule</field>
        <field name="arch" type="xml">
            <search string="Sales Recognition V2">
                <!-- Search Fields -->
                <field name="sale_order_id"/>
                <field name="description"/>
                <field name="recognition_date"/>
                
                <!-- Filters -->
                <filter string="This Month" name="filter_this_month"
                        domain="[('recognition_date', '&gt;=', context_today().replace(day=1)),
                                ('recognition_date', '&lt;=', (context_today() + relativedelta(day=31)))]"/>
                
                <filter string="This Quarter" name="filter_this_quarter"
                        domain="[('recognition_date', '&gt;=', context_today().replace(month=((context_today().month-1)//3)*3+1, day=1)),
                                ('recognition_date', '&lt;=', context_today().replace(month=((context_today().month-1)//3)*3+3, day=31))]"/>
                
                <filter string="This Year" name="filter_this_year"
                        domain="[('recognition_date', '&gt;=', context_today().replace(month=1, day=1)),
                                ('recognition_date', '&lt;=', context_today().replace(month=12, day=31))]"/>
                
                <separator/>
                
                <filter string="Current Year" name="current_year"
                        domain="[('recognition_date', '&gt;=', context_today().replace(month=1, day=1)),
                                ('recognition_date', '&lt;=', context_today().replace(month=12, day=31))]"/>
                
                <filter string="Next Year" name="next_year"
                        domain="[('recognition_date', '&gt;=', (context_today() + relativedelta(years=1)).replace(month=1, day=1)),
                                ('recognition_date', '&lt;=', (context_today() + relativedelta(years=1)).replace(month=12, day=31))]"/>
                
                <filter string="Past Due" name="filter_past_due"
                        domain="[('recognition_date', '&lt;', context_today())]"/>
                
                <filter string="Future" name="filter_future"
                        domain="[('recognition_date', '&gt;=', context_today())]"/>
                
                <separator/>
                
                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Sales Order" name="group_by_sale_order"
                            context="{'group_by': 'sale_order_id'}"/>
                    
                    <filter string="Recognition Date" name="group_by_recognition_date"
                            context="{'group_by': 'recognition_date'}"/>
                    
                    <filter string="Month" name="group_by_month"
                            context="{'group_by': 'recognition_date:month'}"/>
                    
                    <filter string="Quarter" name="group_by_quarter"
                            context="{'group_by': 'recognition_date:quarter'}"/>
                    
                    <filter string="Year" name="group_by_year"
                            context="{'group_by': 'recognition_date:year'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Action - Opens with current year filter and pivot view -->
    <record id="action_sales_recognition_report_v2" model="ir.actions.act_window">
        <field name="name">Sales Recognition V2</field>
        <field name="res_model">sale.order.recognition.schedule</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{
            'search_default_current_year': 1,
            'pivot_measures': ['amount'],
            'pivot_row_groupby': ['sale_order_id'],
            'pivot_column_groupby': ['recognition_date:month']
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No revenue recognition schedules found!
            </p>
            <p>
                This report shows revenue recognition schedule lines with flexible pivot analysis.
                Use the pivot view to analyze revenue by month, quarter, or year.
            </p>
        </field>
    </record>
    
</odoo>
