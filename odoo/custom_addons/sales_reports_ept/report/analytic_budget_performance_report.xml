<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="analytic_budget_performance_report_pivot" model="ir.ui.view">
        <field name="name">analytic.budget.performance.report.pivot</field>
        <field name="model">analytic.budget.performance.report</field>
        <field name="arch" type="xml">
            <pivot string="Budget vs Actual Analysis" sample="1">
                <field name="plan_id" type="row"/>
                <field name="analytic_account_id" type="row"/>
                <field name="date" interval="year" type="col"/>
                <field name="planned_amount" type="measure"/>
                <field name="actual_amount" type="measure"/>
                <field name="variance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="analytic_budget_performance_report_list" model="ir.ui.view">
        <field name="name">analytic.budget.performance.report.list</field>
        <field name="model">analytic.budget.performance.report</field>
        <field name="arch" type="xml">
            <list string="Budget vs Actual" create="false" edit="false" delete="false" sample="1">
                <field name="date"/>
                <field name="plan_id"/>
                <field name="analytic_account_id"/>
                <field name="planned_amount" sum="Budgeted Amount"/>
                <field name="actual_amount" sum="Actual Sales"/>
                <field name="variance" sum="Variance"/>
            </list>
        </field>
    </record>
</odoo>