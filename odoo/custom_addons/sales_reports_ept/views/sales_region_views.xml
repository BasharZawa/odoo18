<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales Region Tree View -->
    <record id="sales_region_tree_view" model="ir.ui.view">
        <field name="name">sales.region.list</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <list string="Sales Regions">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="country_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Sales Region Form View -->
    <record id="sales_region_form_view" model="ir.ui.view">
        <field name="name">sales.region.form</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <form string="Sales Region">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" 
                                class="oe_stat_button" icon="fa-archive"
                                invisible="active">
                            <field name="active" widget="boolean_button" 
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Countries">
                        <field name="country_ids" nolabel="1" widget="many2many_tags">
                            <tree>
                                <field name="name"/>
                                <field name="code"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sales Region Search View -->
    <record id="sales_region_search_view" model="ir.ui.view">
        <field name="name">sales.region.search</field>
        <field name="model">sales.region</field>
        <field name="arch" type="xml">
            <search string="Search Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="country_ids"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Sales Region Action -->
    <record id="sales_region_action" model="ir.actions.act_window">
        <field name="name">Sales Regions</field>
        <field name="res_model">sales.region</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sales_region_search_view"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sales region
            </p>
            <p>
                Group countries into regions (e.g., Gulf, Saudi, Levant) for 
                regional sales analysis.
            </p>
        </field>
    </record>
</odoo>
