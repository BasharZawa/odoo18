<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sales Budget Entry Tree View -->
    <record id="sales_budget_entry_tree_view" model="ir.ui.view">
        <field name="name">sales.budget.entry.list</field>
        <field name="model">sales.budget.entry</field>
        <field name="arch" type="xml">
            <list string="Budget Entries" editable="bottom">
                <field name="year"/>
                <field name="salesperson_id"/>
                <field name="country_id"/>
                <field name="product_line_id"/>
                <field name="budget_amount" sum="Total Budget"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Sales Budget Entry Form View -->
    <record id="sales_budget_entry_form_view" model="ir.ui.view">
        <field name="name">sales.budget.entry.form</field>
        <field name="model">sales.budget.entry</field>
        <field name="arch" type="xml">
            <form string="Budget Entry">
                <sheet>
                    <group>
                        <group string="Budget Dimensions">
                            <field name="year"/>
                            <field name="salesperson_id"/>
                            <field name="country_id"/>
                            <field name="product_line_id"/>
                        </group>
                        <group string="Budget Value">
                            <field name="budget_amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Add notes about this budget entry..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sales Budget Entry Search View -->
    <record id="sales_budget_entry_search_view" model="ir.ui.view">
        <field name="name">sales.budget.entry.search</field>
        <field name="model">sales.budget.entry</field>
        <field name="arch" type="xml">
            <search string="Search Budget Entries">
                <field name="year"/>
                <field name="salesperson_id"/>
                <field name="country_id"/>
                <field name="product_line_id"/>
                <separator/>
                <filter string="Current Year" name="current_year" 
                        domain="[('year', '=', str(context_today().year))]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'salesperson_id'}"/>
                    <filter string="Country" name="group_country" context="{'group_by': 'country_id'}"/>
                    <filter string="Product Line" name="group_product_line" context="{'group_by': 'product_line_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Sales Budget Entry Pivot View -->
    <record id="sales_budget_entry_pivot_view" model="ir.ui.view">
        <field name="name">sales.budget.entry.pivot</field>
        <field name="model">sales.budget.entry</field>
        <field name="arch" type="xml">
            <pivot string="Budget Analysis">
                <field name="year" type="col"/>
                <field name="country_id" type="row"/>
                <field name="product_line_id" type="row"/>
                <field name="budget_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Sales Budget Entry Action -->
    <record id="sales_budget_entry_action" model="ir.actions.act_window">
        <field name="name">Sales Budget Entries</field>
        <field name="res_model">sales.budget.entry</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="search_view_id" ref="sales_budget_entry_search_view"/>
        <field name="context">{'search_default_current_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sales budget entry
            </p>
            <p>
                Define budget values by Year, Salesperson, Country, and Product Line.
                Each combination must be unique.
            </p>
        </field>
    </record>
</odoo>
