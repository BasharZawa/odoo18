<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="odoo_camunda_connector.BpmnEditorWidget" owl="1">
        <div class="o_field_text o_field_widget o_bpmn_editor_widget">
            <div t-if="state.isLoading" class="o_bpmn_loading_indicator">
                Loading BPMN Editor...
            </div>
            <div t-ref="bpmnContainer" class="bpmn-container" t-attf-style="height: {{ props.height || &#39;600px&#39; }}; border: 1px solid #ccc;"/>
            <!-- Optional: Placeholder for properties panel if needed later -->
            <!-- <div id="js-properties-panel" class="bpmn-properties-panel"></div> -->
        </div>
    </t>

</templates>

