<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main Camunda Menu -->
    <menuitem 
        id="camunda_root_menu"
        name="Camunda Workflows"
        sequence="50" 
        web_icon="odoo_camunda_connector,static/description/icon.png"/> <!-- Add an icon later -->

    <!-- Workflow Definitions Menu -->
    <menuitem 
        id="camunda_definitions_menu"
        name="Definitions"
        parent="camunda_root_menu"
        action="camunda_workflow_definition_action"
        sequence="10"/>

    <!-- User Tasks Menu -->
    <menuitem 
        id="camunda_tasks_menu"
        name="Tasks"
        parent="camunda_root_menu"
        sequence="20"/>

    <menuitem 
        id="camunda_user_tasks_submenu"
        name="My Tasks"
        parent="camunda_tasks_menu"
        action="camunda_user_task_action"
        sequence="10"/>

    <!-- Configuration Menu (under Settings) -->
    <menuitem 
        id="camunda_config_menu"
        name="Camunda"
        parent="base.menu_administration"
        sequence="50"
        action="base.action_config_settings"
        groups="base.group_system"/>

</odoo>

