<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="camunda_workflow_definition_view_form" model="ir.ui.view">
        <field name="name">camunda.workflow.definition.form</field>
        <field name="model">camunda.workflow.definition</field>
        <field name="arch" type="xml">
            <form string="Workflow Definition">
                <header>
                    <button name="action_deploy_to_camunda" string="Deploy to Camunda" type="object" class="oe_highlight" attrs="{&#39;invisible&#39;: [(&#39;deployment_status&#39;, &#39;=&#39;, &#39;deployed&#39;)]}"/>
                    <button name="action_deploy_to_camunda" string="Redeploy to Camunda" type="object" attrs="{&#39;invisible&#39;: [(&#39;deployment_status&#39;, &#39;!=&#39;, &#39;deployed&#39;)]}"/>
                    <button name="action_start_instance" string="Start Test Instance" type="object" attrs="{&#39;invisible&#39;: [(&#39;deployment_status&#39;, &#39;!=&#39;, &#39;deployed&#39;)]}" help="Starts a new instance in Camunda using this definition (for testing purposes)."/>
                    <field name="deployment_status" widget="statusbar" statusbar_visible="new,deployed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Add smart buttons later if needed (e.g., link to instances) -->
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g., Order Fulfillment Process"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="camunda_definition_key" readonly="1"/>
                            <field name="camunda_definition_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="camunda_deployment_id" readonly="1"/>
                            <field name="camunda_definition_version" readonly="1"/>
                            <field name="deployment_message" readonly="1" attrs="{&#39;invisible&#39;: [(&#39;deployment_status&#39;, &#39;=&#39;, &#39;new&#39;)]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="BPMN Diagram" name="bpmn_diagram">
                            <!-- Placeholder for the bpmn-js widget -->
                            <field name="bpmn_xml" widget="bpmn_editor" nolabel="1"/>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Detailed description of the workflow..."/>
                        </page>
                        <page string="Raw XML" name="raw_xml">
                             <field name="bpmn_xml" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="camunda_workflow_definition_view_tree" model="ir.ui.view">
        <field name="name">camunda.workflow.definition.tree</field>
        <field name="model">camunda.workflow.definition</field>
        <field name="arch" type="xml">
            <tree string="Workflow Definitions">
                <field name="name"/>
                <field name="camunda_definition_key"/>
                <field name="camunda_definition_version"/>
                <field name="deployment_status"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="camunda_workflow_definition_view_search" model="ir.ui.view">
        <field name="name">camunda.workflow.definition.search</field>
        <field name="model">camunda.workflow.definition</field>
        <field name="arch" type="xml">
            <search string="Search Workflow Definitions">
                <field name="name"/>
                <field name="camunda_definition_key"/>
                <filter string="Deployed" name="deployed" domain="[(&#39;deployment_status&#39;, &#39;=&#39;, &#39;deployed&#39;)]"/>
                <filter string="Not Deployed" name="not_deployed" domain="[(&#39;deployment_status&#39;, &#39;!=&#39;, &#39;deployed&#39;)]"/>
                <filter string="Archived" name="inactive" domain="[(&#39;active&#39;, &#39;=&#39;, False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="camunda_workflow_definition_action" model="ir.actions.act_window">
        <field name="name">Workflow Definitions</field>
        <field name="res_model">camunda.workflow.definition</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new workflow definition.
            </p><p>
                Model your business processes using BPMN 2.0 and deploy them to your Camunda engine.
            </p>
        </field>
    </record>

</odoo>

