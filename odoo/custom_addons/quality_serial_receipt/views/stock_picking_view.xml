<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_open_serial_quality_receipt" model="ir.actions.act_window">
        <field name="name">Serial Quality Inspection</field>
        <field name="res_model">quality.serial.receipt.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">
            {
                'default_picking_id': active_id
            }
        </field>
    </record>

    <record id="stock_picking_form_inherit_serial_quality" model="ir.ui.view">
        <field name="name">stock.picking.serial.quality</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="%(action_open_serial_quality_receipt)d"
                        type="action"
                        string="Serial Quality Inspection"
                        class="btn-primary"
                        invisible="picking_type_code != 'incoming'"/>
            </header>
        </field>
    </record>

</odoo>
