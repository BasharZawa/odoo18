<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_serial_quality_receipt_wizard" model="ir.ui.view">
        <field name="name">quality.serial.receipt.wizard</field>
        <field name="model">quality.serial.receipt.wizard</field>
        <field name="arch" type="xml">
            <form string="Serial Quality Inspection">
                <group>
                    <field name="picking_id" readonly="1"/>
                </group>

                <group>
                    <field name="scanned_serial"
                           placeholder="Scan Serial Number"
                           autofocus="1"/>
                </group>

                <group>
                    <span class="o_form_label">Progress</span>
                    <div>
                        <span>Inspected:</span>
                        <field name="inspected_count" readonly="1"/>
                        <span>Remaining:</span>
                        <field name="remaining_count" readonly="1"/>
                    </div>
                </group>

                <footer>
                    <button name="action_scan_serial"
                            type="object"
                            string="PASS (Enter)"
                            class="btn-primary"/>
                    <button string="Close"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
