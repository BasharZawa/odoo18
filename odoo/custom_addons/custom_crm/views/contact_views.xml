<odoo>
    <data>

        <!-- Inherited Form View for Contacts -->
        <record id="view_res_partner_form_inherited_custom" model="ir.ui.view">
            <field name="name">res.partner.form.inherited.custom</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="studio_customization.odoo_studio_res_part_ef874f8b-02d1-4ee1-a878-91c2b1c3f41a"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='x_IsValidated']" position="after">
                    <!-- <field name="status" widget="statusbar" 
                                statusbar_visible="new,scheduled,completed,canceled" 
                            options="{'clickable': '1'}"
                    /> -->
                    <field name="x_bashar_test" class="oe_inline"/>
                    <button name="action_test" type="object" string="Test Client Action" class="oe_highlight"/>
                    <button name="action_test_raise" type="object" string="Test Raise Action" class="oe_highlight"/>
                </xpath>
            </field>
        </record>


        <record id="view_contact_custom_form" model="ir.ui.view">
            <field name="name">res.partner.custom.form</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <form string="Contact Form">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="list_view_action" model="ir.actions.client">
            <field name="name">List View</field>
            <field name="tag">custom_crm.ListView</field>
        </record>

        <menuitem id="res_partner_menu_contacts_contacts"
        name="Contacts"
        action="contacts.action_contacts"
        parent="contacts.res_partner_menu_contacts"
        sequence="2"/>

        <menuitem id="list_view_action_menu" 
          name="List View" 
          parent="contacts.res_partner_menu_contacts" 
          action="list_view_action"/>

    </data>
</odoo>