<templates xml:space="preserve">
    <t t-name="custom_crm.ListView">
        <div class="o_list_view">
           <h1>Contacts List View</h1>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h2>Contacts</h2>
                <button type="button" class="btn btn-primary" t-on-click="onCreateRecord">Create</button>
            </div>

            <table class="table table-striped table-bordered table-hover table-sm">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Country</th>
                        <th>City</th>
                        <th>Street</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="state.records" t-as="record" t-key="record.id">
                        <tr>
                            <td><t t-esc="record.name"/></td>
                            <td><t t-esc="record.email"/></td>
                            <td><t t-esc="record.phone"/></td>
                            <td><t t-esc="record.country_id[1]"/></td>
                            <td><t t-esc="record.city"/></td>
                            <td><t t-esc="record.street"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>
</templates>