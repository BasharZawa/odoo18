<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="account_analytic_distribution_model_tree_product_line" model="ir.ui.view">
        <field name="name">account.analytic.distribution.model.product.line.list</field>
        <field name="model">account.analytic.distribution.model</field>
        <field name="inherit_id" ref="analytic.account_analytic_distribution_model_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="before">
                <field name="product_line_id" optional="show"/>
            </xpath>
        </field>
    </record>
    <!-- Form View -->
    <record id="account_analytic_distribution_model_form_product_line" model="ir.ui.view">
        <field name="name">account.analytic.distribution.model.product.line.form</field>
        <field name="model">account.analytic.distribution.model</field>
        <field name="inherit_id" ref="analytic.account_analytic_distribution_model_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="before">
                <field name="product_line_id"/>
            </xpath>
        </field>
    </record>
</odoo>