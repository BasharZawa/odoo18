<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Partner Form to add Contact Type and Vendor Code -->
    <record id="view_partner_form_vendor_tracking" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.tracking.ept</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='sales_purchases']" position="inside">
                <group string="Vendor Tracking">
                    <field name="contact_type"/>
                    <field name="vendor_code"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Inherit Partner List to add Vendor Code column (use <list> in Odoo 18) -->
    <record id="view_partner_list_vendor_tracking" model="ir.ui.view">
        <field name="name">res.partner.list.vendor.tracking.ept</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="complete_name" position="after">
                <field name="contact_type"/>
                <field name="vendor_code"/>
            </field>
        </field>
    </record>
</odoo>
