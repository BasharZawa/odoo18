<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_boe_number_form_view" model="ir.ui.view">
        <field name="name">Purchase BOE number form view</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase_delivery_invoice']/group/group" position="inside">
                <field name="boe_number"/>
            </xpath>
        </field>
    </record>
</odoo>
