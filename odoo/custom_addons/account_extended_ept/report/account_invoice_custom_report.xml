<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_custom">
        <t t-call="web.html_container" t-lang="lang">
            <t t-foreach="docs" t-as="doc">
                <!--                <t t-call="web.external_layout">-->
                <t t-call="account_extended_ept.report_sedco_invoicing_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="header" style="padding: 10px 0;">
                            <div style="padding-top: 4pt; padding-bottom: 2pt">
                                <t t-if="doc.company_id.header_img">
                                    <img t-att-src="image_data_uri(doc.company_id.header_img)"
                                         style="width: 100%;" alt="Company Logo"/>
                                </t>
                                <t t-else="">
                                     <img t-if="company.logo" class="o_company_logo_small"
                                          t-att-src="image_data_uri(doc.company_id.logo)" alt="Logo"/>
                                    <div t-if="company.report_header" t-field="company.report_header"
                                         class="o_company_tagline mw-50 fw-bold">Company tagline
                                    </div>
                                </t>
                            </div>
                            <div style="float: left; width: 60%;">
                                <p style="margin: 2px 0; font-size: 15px;">
                                    <b>
                                        <span t-if="doc.company_id.street" t-esc="doc.company_id.street"/>
<!--                                        PO Box 50310, 11523 Riyadh-->
                                        <br/>
                                        <span t-if="doc.company_id.street2" t-esc="doc.company_id.street2"/>
<!--                                        Olaya - Riyadh - Saudi Arabia-->
                                        <br/>
                                        <span t-if="doc.company_id.phone">
                                            Tel <t t-esc="doc.company_id.phone"/>
                                        </span>
                                        <br/>
                                        <br/>
                                    </b>
                                    <a href="https://www.sedco.co" target="_blank"
                                       style="color: blue; text-decoration: underline;">
                                        WWW.SEDCO.CO
                                    </a>
                                    <br/>
                                    <a t-if="doc.company_id.partner_id.vat" href="https://www.sedco.co" target="_blank"
                                       style="color: blue; text-decoration: underline;">
                                        VAT Registration No
                                    </a>
                                    <b>
                                        <span t-if="doc.company_id.partner_id.vat">
                                            <t t-esc="doc.company_id.partner_id.vat or ''"/>
                                        </span>
                                    </b>
                                </p>
                            </div>
                            <div style="float: right; width: 40%; text-align: right; direction: rtl; unicode-bidi: bidi-override;">
                                <p style="margin: 2px 0; font-size: 15px;">
                                    <span t-if="doc.company_id.street_arabic" dir="rtl" t-esc="doc.company_id.street_arabic"/>
<!--                                    <span dir="rtl">ص.ب.</span>-->
<!--                                    50310 <span dir="rtl">الرياض</span> 11523-->
                                    <br/>
                                    <span t-if="doc.company_id.street2_arabic" dir="rtl" t-esc="doc.company_id.street2_arabic"/>
<!--                                    العليا المملكة العربية السعودية الرياض- -->
                                    <br/>
                                    <b>
                                        <span t-if="doc.company_id.phone" dir="rtl">هاتف</span>
                                        <t t-esc="doc.company_id.phone"/>
                                    </b><br/>
                                    <br/>
                                    <a href="https://www.sedco.co" target="_blank"
                                       style="color: blue; text-decoration: underline;">
                                        WWW.SEDCO.CO
                                    </a>
                                    <br/>
                                    <a href="https://www.sedco.co" target="_blank"
                                       style="color: blue; text-decoration: underline;">
                                        <span dir="rtl">
                                             رقم السجل الضريبي
                                        </span>
                                    </a>
                                    <b>
                                        <span t-if="doc.company_id.partner_id.vat" dir="rtl"
                                              t-esc="doc.company_id.partner_id.vat or ''"/>
                                    </b>
                                </p>
                            </div>


                            <div style="height: 48px; border:2px solid #000; border-radius:12px; padding:7px ; width:250px; margin:160px auto 10px auto; text-align:center; font-size:15px; font-weight:bold;">
                                <span style="float: left; padding: 3px">TAX INVOICE</span>
                                <span dir="rtl" style="font-size:18px; float: right; letter-spacing: -2px">
                                    فاتورة ضريبية
                                </span>
                            </div>
                            <div>
                                <!-- Left table-->
                                <div class="col-6"
                                     style="float:left; width:48.5%; margin-right:1%; margin-left:1%; font-size:15px;">
                                    <table style="width:100%; height:300px; table-layout:fixed;
                                            margin-bottom:20px; border-collapse:collapse; border:1px solid #000">
                                        <tr>
                                            <td style="width: 50%; vertical-align: top; border: 1px solid #000; padding: 5px;">
                                                <strong>Bill To /
                                                    <span dir="rtl">فاتورة العميل</span>
                                                </strong>
                                                <br/>
                                                <strong>Customer ID:</strong>
                                                <span t-esc="doc.partner_id.ref"/>
                                                <br/>
                                                <span t-esc="doc.partner_id.name"/>
                                                <br/>
                                                <span t-esc="doc.partner_id.country_id.name"/>
                                                <br/>
                                                <strong>Tel:</strong>
                                                <span t-esc="doc.partner_id.phone"/>
                                                <br/>
                                                <table style="margin-top:40px ;width: 100%; border-color: white;">
                                                    <tr style="line-height: 85%;">
                                                        <td style="width: 30%; height:10px">VAT No</td>
                                                        <td style="width: 40%; text-align: right; height:10px"
                                                            dir="rtl">
                                                            رقم الضريبة
                                                        </td>
                                                        <td style="padding: 8px; width: 30%; text-align: left; height:10px"
                                                            t-esc="doc.company_id.partner_id.vat or ''"/>
                                                    </tr>
                                                    <tr style="line-height: 85%;">
                                                        <td style="padding: 2px; height:10px;">PO No./</td>
                                                        <td style="padding: 2px; text-align: right; height:10px;"
                                                            dir="rtl">
                                                            رقم أمر شراء
                                                        </td>
                                                        <td style="padding: 8px; text-align: left; height:10px;"
                                                            t-esc="doc.invoice_origin or ''"/>
                                                    </tr>
                                                    <tr style="line-height: 85%;">
                                                        <td style="padding: 2px; height:10px;">Payment term/</td>
                                                        <td style="padding: 2px; text-align: right; height:10px;"
                                                            dir="rtl">
                                                            طريقة الدفع
                                                        </td>
                                                        <td style="padding: 8px; text-align: left; height:10px;"
                                                            t-esc="doc.invoice_payment_term_id.name or ''"/>
                                                    </tr>
                                                    <tr style="line-height: 85%;">
                                                        <td style="height:10px">Due Date/</td>
                                                        <td style="text-align: right; height:10px;" dir="rtl">
                                                            تاريخ الاستحقاق
                                                        </td>
                                                        <t t-if="doc.invoice_date_due">
                                                            <td style="padding: 8px; text-align: left; height:10px;"
                                                                t-esc="doc.invoice_date_due.strftime('%d/%m/%Y') or ''"/>
                                                        </t>
                                                        <t t-else="">
                                                            <td/>
                                                        </t>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <!-- Right table-->
                                <div class="col-6" style="float:left; width:48.5%; font-size:15px;">
                                    <table style="width: 100%; height:300px; table-layout:fixed;
                                            margin-bottom: 20px; border-collapse:collapse; border: 1px solid #000">
                                        <tr style="height: 167px; border-left: 3px solid #000;">
                                            <td style="width: 56%; background-color: #CCCCCC">
                                                <span style="margin-left:5px">
                                                    <strong>VAT No /</strong>
                                                </span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">رقم الضريبة
                                                </span>
                                                <br/>
                                                <span style="margin-left:5px" t-esc="doc.company_id.partner_id.vat"/>
                                            </td>
                                            <td style="width: 45%;"/>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Invoice No /</span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">رقم
                                                    الفاتورة
                                                </span>
                                            </td>
                                            <td>
                                                <span style="margin-left:5px">
                                                    <t t-esc="doc.name"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Invoice Date /</span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">
                                                    تاريخ الفاتورة
                                                </span>
                                            </td>
                                            <td>
                                                <span style="margin-left:5px">
                                                    <t t-if="doc.invoice_date">
                                                        <t t-esc="doc.invoice_date.strftime('%d/%m/%Y')"/>
                                                    </t>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Shipping Method /</span>
                                                <span style="float: right; margin-right: 5px" dir="rtl">طريقة الشحن
                                                </span>
                                            </td>
                                            <t t-if="doc.invoice_line_ids">
                                                <td>
                                                    <span style="margin-left:5px">
                                                        <t t-esc="doc.invoice_line_ids[0].sale_line_ids.order_id.carrier_id.name or ''"/>
                                                    </span>
                                                </td>
                                            </t>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Currency /</span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">العملة
                                                </span>
                                            </td>
                                            <td>
                                                <span style="margin-left:5px">
                                                    <t t-esc="doc.currency_id.name"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Sales Order /</span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">
                                                    طلب المبيعات
                                                </span>
                                            </td>
                                            <td>
                                                <span style="margin-left:5px">
                                                    <t t-esc="doc.invoice_origin"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr style="border-left: 3px solid #000;">
                                            <td style="background-color: #CCCCCC">
                                                <span style="margin-left:5px">Page /</span>
                                                <span style="float: right;margin-right: 5px" dir="rtl">الصفحة
                                                </span>
                                            </td>
                                            <td>
                                                <span style="margin-left:5px">Page
                                                    <span class="page"/>
                                                    of
                                                    <span class="topage"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div style="font-size:15px;">
                            <!-- Invoice Lines -->
                            <table style="width: 100%; table-layout:fixed">
                                <thead>
                                    <tr style="background-color: #CCCCCC;">

                                        <th style="border: 2px solid #000; border-right: 0px; padding: 8px; text-align: center; font-weight: bold; width: 12%;">
                                            Model number
                                            <br/>
                                            <span dir="rtl">رقم الموديل</span>
                                        </th>
                                        <!--                                        <th style="border: 2px solid #000; border-right: 0px; padding: 8px; text-align: center; font-weight: bold;">-->
                                        <!--                                            Item Number-->
                                        <!--                                            <br/>-->
                                        <!--                                            <span dir="rtl">رقم الصنف</span>-->
                                        <!--                                        </th>-->
                                        <th style="border: 2px solid #000; border-right: 0px; border-left: 0px; padding: 8px; text-align: center; font-weight: bold; width: 27%;">
                                            Description
                                            <br/>
                                            <span dir="rtl">الوصف</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold; width: 7%;">
                                            Qty
                                            <br/>
                                            <span dir="rtl">الكمية</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold;">
                                            Unit Price
                                            <br/>
                                            <span dir="rtl">سعر الوحدة</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold;">
                                            Discount
                                            <br/>
                                            <span dir="rtl">الخصم</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold;">
                                            Ext Price
                                            <br/>
                                            <span dir="rtl">إجمالي السعر</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold;">
                                            VAT %
                                            <br/>
                                            <span dir="rtl">نسبة الضريبة</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-right: 0px; border-left: 0px; font-weight: bold;">
                                            VAT
                                            <br/>
                                            <span dir="rtl">ضريبة</span>
                                        </th>
                                        <th style="border: 2px solid #000; padding: 8px; text-align: center; border-left: 0px; font-weight: bold;">
                                            Total
                                            <br/>
                                            <span dir="rtl">الإجمالي</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.invoice_line_ids" t-as="line"
                                        style="border: 1px solid #000; border-bottom: 0px; border-top: 0px;">
                                        <!--                                        <td style="border: 2px solid #000; border-bottom: 0px; border-top: 0px; padding: 8px; text-align: center;">-->
                                        <!--                                            <span t-esc="line.product_id.default_code"/>-->
                                        <!--                                        </td>-->
                                        <!--                                        <td style="border: 2px solid #000; border-bottom: 0px; border-top: 0px; padding: 8px;">-->
                                        <!--                                            <span t-esc="line.name"/>-->
                                        <!--                                        </td>-->
                                        <td style="border: 2px solid #000; border-bottom: 0px; border-top: 0px; padding: 8px; text-align: center;">
                                            <span t-esc="line.product_id.model_number"/>
                                        </td>
                                        <td style="border: 2px solid #000; border-bottom: 0px; border-top: 0px; padding: 8px;">
                                            <span t-esc="line.product_id.name"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: center;">
                                            <span t-esc="line.quantity"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: right;">
                                            <span t-esc="line.price_unit"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: right;">
                                            <span t-esc="line.discount"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: right;">
                                            <span t-esc="line.price_subtotal"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: center;">
                                            <span t-esc="', '.join(line.tax_ids.mapped('name'))"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: right;">
                                            <span t-esc="'%.2f' % (line.price_total - line.price_subtotal)"/>
                                        </td>
                                        <td style="border: 2px solid #000; padding: 8px; border-bottom: 0px; border-top: 0px; text-align: right;">
                                            <span t-esc="'%.2f' % line.price_total"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <!-- Totals -->
                        <div style="font-size:15px; page-break-before: always;">
                            <div style="min-height: 1px;"/>
                            <div t-att-style="doc.company_id.state_id.code == 'DU' and 'margin-top:288px;' or 'margin-top:388px;'">
                                <table style="width: 100%; border-color: white; margin-top: 10px">
                                    <tr style="border: 2px solid #000; border-left: 0px;">
                                        <td style="width: 52%; border-left: 0px; vertical-align: middle;">
                                            <strong style="margin-left: 5px;">In Words SAR:</strong>
                                        </td>
                                        <td style="width: 32%; border: 2px solid #000; vertical-align: middle;">
                                            <span style="margin-left: 5px;">Total Before Discount</span>
                                        </td>
                                        <t t-set="amount_before_tax_discount"
                                           t-value="sum(line.price_unit * line.quantity for line in doc.invoice_line_ids)"/>

                                        <td style="width: 16%; border: 2px solid #000; vertical-align: middle;">
                                            <span style="margin-left: 5px; float: right;">
                                                <t t-esc="doc.currency_id.name"/>
                                                <t t-esc="'%.2f' % amount_before_tax_discount"/>
                                            </span>
                                        </td>
                                    </tr>
                                    <tr style="border-bottom: 0px; line-height: 90%;">
                                        <td style="border-bottom: 0px; border-left: 0px; font-weight: bold;"
                                            rowspan="2">
                                            <t t-set="amount_in_words"
                                               t-value="doc.currency_id.amount_to_text(doc.amount_total)"/>
                                            <div style="margin-left: 5px; margin-top: 5px;">
                                                <t t-esc="amount_in_words"/>
                                                Only
                                            </div>
                                        </td>
                                        <td style="border: 2px solid #000; height: 22px; vertical-align: middle;">
                                            <span style="margin-left: 5px;">Total Disc /</span>
                                            <span style="float: right; margin-right: 5px" dir="rtl">إجمالي
                                                الخصم
                                            </span>
                                        </td>
                                        <t t-set="total_discount"
                                           t-value="sum((line.price_unit * line.quantity * line.discount) / 100 for line in doc.invoice_line_ids)"/>

                                        <td style="text-align: right; border: 2px solid #000; vertical-align: middle;">
                                            <span style="margin-left: 5px;">
                                                <t t-esc="doc.currency_id.name"/>
                                                <t t-esc="'%.2f' % total_discount"/>
                                            </span>
                                        </td>
                                    </tr>
                                    <tr style="border-top: 0px; border-bottom: 0px;">
                                        <td style="border: 2px solid #000;">
                                            <span style="margin-left: 5px;">Net Amount /</span>
                                            <span style="float: right; margin-right: 5px" dir="rtl">المبلغ
                                                الصافي
                                            </span>
                                        </td>
                                        <td style="text-align: right; border: 2px solid #000;">
                                            <t t-esc="doc.currency_id.name"/>
                                            <t t-esc="'%.2f' % (amount_before_tax_discount - total_discount)"/>
                                        </td>
                                    </tr>
                                    <tr style="border-top: 0px; border-bottom: 0px;">
                                        <td style="border-top: 0px; border-bottom: 0px; border-left: 0px;">
                                        </td>
                                        <td style="border: 2px solid #000;">
                                            <span style="margin-left: 5px;">VAT Total /</span>
                                            <span style="float: right; margin-right: 5px" dir="rtl">
                                                إجمالي ضريبة القيمة المضافة
                                            </span>
                                        </td>
                                        <td style="text-align: right; border: 2px solid #000;">
                                            <span style="margin-left: 5px;">
                                                <t t-esc="doc.currency_id.name"/>
                                                <t t-esc="doc.amount_tax"/>
                                            </span>
                                        </td>
                                    </tr>
                                    <tr style="border-top: 0px; border-bottom: 0px;">
                                        <td style="border-top: 0px; border-bottom: 0px; border-left: 0px;">
                                            <strong style="margin-left: 5px;">
                                                This is computer generated invoice no signature requires
                                            </strong>
                                        </td>
                                        <td style="border: 2px solid #000;">
                                            <strong style="margin-left: 5px;">Total Amount /</strong>
                                            <span style="float: right; margin-right: 5px" dir="rtl">
                                                <strong>الإجمالي</strong>
                                            </span>
                                        </td>
                                        <td style="text-align: right; border: 2px solid #000;">
                                            <span style="margin-left: 5px;">
                                                <strong>
                                                    <t t-esc="doc.currency_id.name"/>
                                                    <t t-esc="doc.amount_total"/>
                                                </strong>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <table t-if="doc.company_id.state_id.code == 'DU'"
                                   style="width:100%; margin-top:25px; font-size:15px; border-color: white;">
                                <tr>
                                    <!-- Left Bank Details -->
                                    <td style="width:50%; text-align:center; vertical-align:top;">
                                        <strong>Bank Details</strong><br/>
                                        <strong style="font-size:13px">
                                        Systems And Electronic Development FZCO<br/>
                                        A/C No. 01-2315041-01<br/>
                                        Standard Chartered Bank, Dubai Branch<br/>
                                        IBAN AED NO. AE970440000001231504101
                                        </strong>
                                    </td>

                                    <!-- Right Bank Details -->
                                    <td style="width:50%; text-align:center; vertical-align:top;">
                                        <strong>Bank Details</strong><br/>
                                        <strong style="font-size:13px">
                                        Systems And Electronic Development FZCO<br/>
                                        A/C No. 01-2315041-01<br/>
                                        Standard Chartered Bank, Dubai Branch<br/>
                                        IBAN USD NO. AE590440000101231504101
                                        </strong>
                                    </td>
                                </tr>
                            </table>

                            <t t-if="doc.company_id.state_id.code == 'DU'">
                                <div style="margin-top: 20px; padding: 15px; text-align: center;">
                                    <!-- Horizontal line at start -->
                                    <hr style="border: 0; height: 2px; background: #000000; margin: 0 -50px 15px -50px;"/>
                                    <p style="margin: 0; letter-spacing: -0.5px; word-spacing: -1px;">
                                        شركة ذات مسئولية محدودة تأسست بموجب القانون رقم 2 لسنة 1986 ووفقا للا ئحة
                                        التنفيذية رقم 1 لسنة 1999
                                    </p>
                                    <p style="margin: 2px 0 0 0;">
                                        Formed Pursuant to Law No. 2 of 1986 &amp; Implementing Regulation No. 1 of 1999
                                        with Limited Liability
                                    </p>
                                </div>
                            </t>
                            <t t-else="">
                                <div style="margin-top: 20px; padding: 15px; text-align: center; font-weight: bold; line-height: 40%;">
                                    <p>BENEFICIARY : SYSTEMS AND ELECTRONIC DEVELOPMENT BR- RIYADH</p>
                                    <p>BANK : THE SAUDI BRITISH BANK</p>
                                    <p>BRANCH ADDRESS : AL WOROOD BRANCH, KING ABDULAZIZ RD, RIYADH</p>
                                    <p>IBAN NO: SA31 4500 0000 0171 4981 6001</p>
                                    <p style="font-weight: bold;">THANK YOU FOR YOUR BUSINESS!</p>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_sedco_invoicing_layout">
        <t t-if="not o" t-set="o" t-value="doc"/>

        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>

        <t t-out="0"/>

        <!-- ========================= FIXED HEADER DIV ========================= -->
        <div t-attf-class="header o_company_#{company.id}_layout"
             style="position: fixed; top: 0; left: 0; right: 0; height: 280px; background: white; z-index: 10;">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <img t-if="company.logo" class="o_company_logo_small" t-att-src="image_data_uri(company.logo)"
                     alt="Logo"/>
                <div t-if="company.report_header" t-field="company.report_header"
                     class="o_company_tagline mw-50 fw-bold">Company tagline
                </div>
            </div>
            <div class="row">
                <div class="col-6" name="company_address">
                    <ul class="list-unstyled" name="company_address_list">
                        <li t-if="company.is_company_details_empty">
                            <span t-field="company.partner_id"
                                  t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'>
                                <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                    <strong>Company address block</strong>
                                    <div>Contains the company address.</div>
                                </div>
                            </span>
                        </li>
                        <li t-else="">
                            <span t-field="company.company_details">
                                <div class="bg-light border-1 rounded h-100 d-flex flex-column align-items-center justify-content-center p-4 w-100 opacity-75 text-muted text-center">
                                    <strong>Company details block</strong>
                                    <div>Contains the company details.</div>
                                </div>
                            </span>
                        </li>
                        <li t-if="not forced_vat"/>
                        <li t-else="">
                            <t t-esc="company.country_id.vat_label or 'Tax ID'">Tax ID</t>:
                            <span t-esc="forced_vat">US12345671</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- ========================= BODY ========================= -->
        <div t-attf-class="article o_report_layout_standard o_table_standard o_company_#{company.id}_layout o_snail_mail {{'o_report_layout_background' if company.layout_background != 'Blank' else ''}}"
             t-attf-style="margin-top: 290px; background-image: url({{ 'data:image/png;base64,%s' % company.layout_background_image.decode('utf-8') if company.layout_background_image and company.layout_background == 'Custom' else '/base/static/img/demo_logo_report.png' if company.layout_background == 'Demo logo' else ''}});"
             t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
             t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-call="web.address_layout"/>
            <h2 t-out="layout_document_title"/>
            <t t-out="0"/>
        </div>
    </template>

    <record id="custom_invoice_paperformat" model="report.paperformat">
        <field name="name">SEDCO Invoice Paperformat</field>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">135</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">135</field>
        <field name="dpi">90</field>
        <field name="css_margins" eval="True"/>
    </record>

    <record id="action_report_invoice_sedco" model="ir.actions.report">
        <field name="name">SEDCO Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_extended_ept.report_invoice_document_custom</field>
        <field name="print_report_name">'SEDCO Invoice - %s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="account_extended_ept.custom_invoice_paperformat"/>
    </record>

</odoo>
