<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_header_res_company_form_view" model="ir.ui.view">
        <field name="name">Invoice Header Res Company</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="priority" eval="15"/>
        <field name="arch" type="xml">
            <field name="vat" position="before">
                <label for="street_arabic" string="Address (Arabic)"/>
                <div class="o_address_format">
                    <field name="street_arabic" placeholder="Street" class="o_address_street"
                           style="direction: rtl; text-align: right;"/>
                    <field name="street2_arabic" placeholder="Street 2" class="o_address_street"
                           style="direction: rtl; text-align: right;"/>
                </div>
            </field>
            <field name="phone" position="after">
                <field name="fax"/>
            </field>
            <field name="currency_id" position="after">
                <field name="header_img" widget="image"/>
            </field>
        </field>
    </record>
</odoo>
