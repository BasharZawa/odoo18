<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_delivery_document_model_number_inherited" inherit_id="stock.report_delivery_document">
        <xpath expr="//table[@name='stock_move_table']/thead//th[@name='th_sm_product']" position="after">
            <th name="th_model_number">Model Number</th>
            <th t-if="o.picking_type_id.code == 'incoming'">
                Product Vendor Code
            </th>
        </xpath>

        <xpath expr="//span[@t-field='move.product_id']/.." position="after">
            <td>
                <span t-field="move.model_number"/>
            </td>
            <td t-if="o.picking_type_id.code == 'incoming'">
                <t t-set="vendor" t-value="o.purchase_id.partner_id"/>
                <t t-set="seller"
                t-value="vendor and move.product_id.seller_ids.filtered(lambda s: s.partner_id == vendor)[:1]"/>
                <span t-if="seller" t-esc="seller.product_code"/>
            </td>
        </xpath>

        <xpath expr="//span[@t-field='move.product_id']" position="replace">
            <span t-field="move.product_id.name"/>
        </xpath>


        <xpath expr="//table[@name='stock_move_line_table']/thead//th[@name='th_sml_product']" position="after">
            <th name="th_model_number">Model Number</th>
            <th t-if="o.picking_type_id.code == 'incoming'">
                Product Vendor Code
            </th>
        </xpath>


        <!-- Backorders       -->
        <xpath expr="//table[@name='stock_backorder_table']/thead//th[@name='th_sb_product']" position="after">
            <th name="th_model_number">Model Number</th>
            <th t-if="o.picking_type_id.code == 'incoming'">
                Product Vendor Code
            </th>
        </xpath>

        <xpath expr="//span[@t-field='bo_line.product_id']/.." position="after">
            <td>
                <td><span t-field="bo_line.model_number"/></td>
            </td>
            <td t-if="o.picking_type_id.code == 'incoming'">
                <t t-set="vendor" t-value="o.purchase_id.partner_id"/>
                <t t-set="seller"
                t-value="vendor and bo_line.product_id.seller_ids.filtered(lambda s: s.partner_id == vendor)[:1]"/>
                <span t-if="seller" t-esc="seller.product_code"/>
            </td>
        </xpath>
        <!--       -->
    </template>

    <template id="stock_report_delivery_has_serial_ml_model_number_inherited"
              inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//span[@t-field='move_line.product_id']/.." position="after">
            <td><span t-field="move_line.move_id.model_number"/></td>
            <td t-if="o.picking_type_id.code == 'incoming'">
                <t t-set="vendor" t-value="o.purchase_id.partner_id"/>
                <t t-set="seller"
                t-value="vendor and move_line.move_id.product_id.seller_ids.filtered(lambda s: s.partner_id == vendor)[:1]"/>
                <span t-if="seller" t-esc="seller.product_code"/>
            </td>
        </xpath>
        <xpath expr="//span[@t-field='move_line.product_id']" position="replace">
            <span t-field="move_line.product_id.name"/>
        </xpath>
    </template>

    <template id="stock_report_delivery_aggregated_ml_model_number_inherited"
              inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//span[@t-esc=concat('aggregated_lines[line][', &quot;'name'&quot;, ']')]/.." position="after">
            <td><span t-field="aggregated_lines[line].get('move').model_number"/></td>
            <td t-if="o.picking_type_id.code == 'incoming'">
                <t t-set="vendor" t-value="o.purchase_id.partner_id"/>
                <t t-set="seller"
                t-value="vendor and aggregated_lines[line].get('move').product_id.seller_ids.filtered(lambda s: s.partner_id == vendor)[:1]"/>
                <span t-if="seller" t-esc="seller.product_code"/>
            </td>
        </xpath>
        <xpath expr="//span[@t-esc=concat('aggregated_lines[line][', &quot;'name'&quot;, ']')]" position="replace">
            <span t-esc="aggregated_lines[line].get('product').name"/>
        </xpath>

    </template>

    <template id="report_package_barcode_model_number_inherited"
              inherit_id="stock.report_package_barcode">
        <xpath expr="//th[@name='th_product']" position="after">
            <th name="th_model_number">Model Number</th>
        </xpath>
        <xpath expr="//t[@t-foreach='package_quants.product_id']//th[@name='th_product']" position="after">
            <th name="th_model_number" class="text-start">
                <span t-field="product.model_number"/>
            </th>
        </xpath>
        <xpath expr="//t[@t-foreach='package_quants.product_id']//th[@name='th_product']/span" position="replace">
            <span t-field="product.name"/>
        </xpath>
    </template>
</odoo>
