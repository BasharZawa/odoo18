<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="sale_report_model_number_inherited" inherit_id="sale.report_saleorder_document">

        <xpath expr="//table[contains(@class, 'o_has_total_table')]//th[@name='th_description']" position="after">
            <th name="th_model_number" class="text-start">Model Number</th>
        </xpath>

        <xpath expr="//table[contains(@class, 'o_has_total_table')]/tbody//td[@name='td_name']" position="after">
            <td name="td_model_number"><span t-field="line.model_number" class="text-start"/></td>
        </xpath>
        <xpath expr="//td[@name='td_name']/span[@t-field='line.name']"
               position="replace">
            <span t-field="line.product_id.name"/>
        </xpath>
    </template>

    <!--    Sales report add Product line and Product nature fields in search view-->
    <record id="view_order_product_search_extended" model="ir.ui.view">
        <field name="name">sale.report.search.extended</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group/filter[@name='company']" position="after">
                <filter string="Product Line" name="product_line_id" context="{'group_by':'product_line_id'}"/>
                <filter string="Product Nature" name="product_nature_id" context="{'group_by':'product_nature_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
