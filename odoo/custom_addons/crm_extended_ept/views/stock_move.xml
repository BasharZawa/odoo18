<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_move_model_number_form" model="ir.ui.view">
        <field name="name">stock.move.model.number.ept</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='operations']//list//field[@name='product_id']" position="after">
                <field name="model_number" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_filter_search" model="ir.ui.view">
        <field name="name">stock.move.filter.search</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter string="Product Line" name="product_line_id" context="{'group_by':'product_line_id'}"/>
                <filter string="Product Nature" name="product_nature_id" context="{'group_by':'product_nature_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_line_filter_search" model="ir.ui.view">
        <field name="name">stock.move.line.filter.search</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.stock_move_line_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter string="Product Line" name="product_line_id" context="{'group_by':'product_line_id'}"/>
                <filter string="Product Nature" name="product_nature_id" context="{'group_by':'product_nature_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
