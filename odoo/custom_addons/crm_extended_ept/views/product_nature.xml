<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_nature_tree_view" model="ir.ui.view">
        <field name="name">product.nature.tree.view</field>
        <field name="model">product.nature.ept</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_product_nature_ept" model="ir.actions.act_window">
        <field name="name">Product Nature</field>
        <field name="res_model">product.nature.ept</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a new record!</p>
        </field>
    </record>

    <menuitem id="menu_action_product_nature_ept" action="action_product_nature_ept"
              parent="stock.menu_stock_inventory_control" sequence="103"/>
</odoo>
