<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_line_model_number_form" model="ir.ui.view">
        <field name="name">purchase.order.line.model.number.ept</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='products']//list//field[@name='product_qty']" position="before">
                <field name="model_number" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
