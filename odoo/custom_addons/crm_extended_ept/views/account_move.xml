<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_line_model_number_form" model="ir.ui.view">
        <field name="name">account.move.line.model.number.ept</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoice_tab']//list//field[@name='product_id']" position="after">
                <field name="model_number" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_line_filter_search" model="ir.ui.view">
        <field name="name">account.move.line.filter.search</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter string="Product Line" name="product_line_id" context="{'group_by':'product_line_id'}"/>
                <filter string="Product Nature" name="product_nature_id" context="{'group_by':'product_nature_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
