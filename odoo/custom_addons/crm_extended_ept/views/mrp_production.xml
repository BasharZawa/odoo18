<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_model_number_form" model="ir.ui.view">
        <field name="name">mrp.production.model.number.ept</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group/group/field[@name='product_tmpl_id']" position="after">
                <field name="model_number" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
