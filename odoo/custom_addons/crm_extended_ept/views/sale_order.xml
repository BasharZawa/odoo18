<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_line_model_number_form" model="ir.ui.view">
        <field name="name">sale.order.line.model.number.ept</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']//list//field[@name='product_template_id']" position="after">
                <field name="model_number" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
