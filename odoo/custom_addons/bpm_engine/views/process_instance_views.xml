<odoo>
    <record id="view_bpmn_process_instance_form" model="ir.ui.view">
        <field name="name">bpmn.process.instance.form</field>
        <field name="model">bpmn.process.instance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="process_definition_id"/>
                        <field name="state"/>
                        <field name="started_at"/>
                        <field name="ended_at"/>
                        <field name="related_record_model"/>
                        <field name="related_record_id"/>
                    </group>
                    <notebook>
                        <page string="Tasks">
                            <field name="task_instance_ids"/>
                        </page>
                        <page string="Variables">
                            <field name="variable_ids"/>
                        </page>
                        <page string="Logs">
                            <field name="log_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bpmn_process_instance" model="ir.actions.act_window">
        <field name="name">Process Instances</field>
        <field name="res_model">bpmn.process.instance</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
