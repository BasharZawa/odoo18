<odoo>
    <record id="view_bpmn_task_instance_tree" model="ir.ui.view">
        <field name="name">bpmn.task.instance.tree</field>
        <field name="model">bpmn.task.instance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="process_instance_id"/>
                <field name="task_type"/>
                <field name="task_name"/>
                <field name="status"/>
                <field name="assigned_user_id"/>
                <field name="started_at"/>
                <field name="completed_at"/>
            </tree>
        </field>
    </record>
    <record id="action_bpmn_my_tasks" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">bpmn.task.instance</field>
        <field name="domain">[('assigned_user_id', '=', uid), ('status', '=', 'ready')]</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
