<odoo>
    <record id="view_bpmn_process_definition_form" model="ir.ui.view">
        <field name="name">bpmn.process.definition.form</field>
        <field name="model">bpmn.process.definition</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Activate" name="action_activate" type="object" attrs="{'invisible':[('is_active','=',True)]}"/>
                    <button string="Deactivate" name="action_deactivate" type="object" attrs="{'invisible':[('is_active','=',False)]}"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="version"/>
                        <field name="description"/>
                        <field name="is_active"/>
                        <field name="created_by"/>
                        <field name="created_at"/>
                    </group>
                    <group>
                        <field name="xml_data" widget="bpmn_modeler"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_bpmn_process_definition" model="ir.actions.act_window">
        <field name="name">Process Definitions</field>
        <field name="res_model">bpmn.process.definition</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
