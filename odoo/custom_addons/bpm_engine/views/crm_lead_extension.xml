<odoo>
    <record id="crm_lead_form_bpmn_ext" model="ir.ui.view">
        <field name="name">crm.lead.form.bpmn.ext</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_form_view_oppor"/>
        <field name="arch" type="xml">
            <header position="after">
                <button name="action_start_bpmn_process" string="Start BPMN Process" type="object"
                    attrs="{'invisible': [('bpmn_instance_id','!=',False)]}" class="oe_highlight"/>
                <field name="bpmn_instance_id" readonly="1"/>
            </header>
        </field>
    </record>
</odoo>
