<odoo>
    <record id="view_bpmn_activity_log_tree" model="ir.ui.view">
        <field name="name">bpmn.activity.log.tree</field>
        <field name="model">bpmn.activity.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="process_instance_id"/>
                <field name="action_type"/>
                <field name="timestamp"/>
                <field name="actor_id"/>
                <field name="details"/>
            </tree>
        </field>
    </record>
    <record id="action_bpmn_logs" model="ir.actions.act_window">
        <field name="name">Activity Logs</field>
        <field name="res_model">bpmn.activity.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
