<odoo>
    <record id="view_purchase_order_change_wizard_form" model="ir.ui.view">
        <field name="name">purchase.order.change.wizard.form</field>
        <field name="model">purchase.order.change.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Purchase Order">
                <group>
                    <field name="purchase_id" readonly="1"/>
                    <field name="new_name"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
