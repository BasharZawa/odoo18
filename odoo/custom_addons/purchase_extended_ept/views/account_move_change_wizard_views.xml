<odoo>
    <record id="view_account_move_change_wizard_form" model="ir.ui.view">
        <field name="name">account.move.change.wizard.form</field>
        <field name="model">account.move.change.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Invoice Number">
                <group>
                    <field name="move_id" readonly="1"/>
                    <field name="new_name"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
