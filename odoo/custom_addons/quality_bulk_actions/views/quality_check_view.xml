<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Server Action for Bulk Pass -->
    <record id="server_action_bulk_pass" model="ir.actions.server">
        <field name="name">Pass</field>
        <field name="model_id" ref="quality.model_quality_check"/>
        <field name="binding_model_id" ref="quality.model_quality_check"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Bulk Pass',
    'res_model': 'quality.check.bulk.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': records.ids, 'default_action_type': 'pass'},
}
        </field>
        <field name="groups_id" eval="[(4, ref('quality.group_quality_user'))]"/>
    </record>

    <!-- Server Action for Bulk Fail -->
    <record id="server_action_bulk_fail" model="ir.actions.server">
        <field name="name">Fail</field>
        <field name="model_id" ref="quality.model_quality_check"/>
        <field name="binding_model_id" ref="quality.model_quality_check"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Bulk Fail',
    'res_model': 'quality.check.bulk.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': records.ids, 'default_action_type': 'fail'},
}
        </field>
        <field name="groups_id" eval="[(4, ref('quality.group_quality_user'))]"/>
    </record>

</odoo>
