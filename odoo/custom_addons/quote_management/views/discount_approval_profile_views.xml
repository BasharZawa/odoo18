<odoo>
  <record id="view_discount_approval_profile_form" model="ir.ui.view">
    <field name="name">discount.approval.profile.form</field>
    <field name="model">discount.approval.profile</field>
    <field name="arch" type="xml">
      <form string="Discount Approval Profile">
        <group>
          <field name="user_id"/>
          <field name="product_nature"/>
          <field name="max_discount"/>
        </group>
      </form>
    </field>
  </record>

<record id="view_discount_approval_profile_list" model="ir.ui.view">
    <field name="name">discount.approval.profile.list</field>
    <field name="model">discount.approval.profile</field>
    <field name="arch" type="xml">
        <list string="Discount Approval Profiles" editable="bottom" create="true">
            <field name="user_id"/>
            <field name="product_nature"/>
            <field name="max_discount"/>
        </list>
    </field>
</record>

  <record id="discount_approval_profile_action" model="ir.actions.act_window">
    <field name="name">Discount Profiles</field>
    <field name="res_model">discount.approval.profile</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_discount_approval_root" name="Discount Approvals" parent="sale.sale_menu_root" sequence="30"/>
  <menuitem id="menu_discount_approval_profiles" name="Discount Profiles" parent="menu_discount_approval_root" action="discount_approval_profile_action"/>

</odoo>