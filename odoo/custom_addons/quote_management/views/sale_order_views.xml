<odoo>
  <record id="view_order_form_inherit_quotation_gp_ext" model="ir.ui.view">
    <field name="name">sale.order.form.revision.gp</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='payment_term_id']" position="after">
          <field name="incoterm_location"/>
          <field name="warranty_months"/>
          <field name="delivery_time"/>
      </xpath>

      <xpath expr="//header" position="inside">
        <button name="action_create_revision" string="Create Revision" type="object"
                class="btn-secondary" invisible="state != 'sent'"/>
      </xpath>
    </field>
  </record>
</odoo>