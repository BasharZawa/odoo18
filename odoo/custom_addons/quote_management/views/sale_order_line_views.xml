<odoo>
  <record id="view_order_form_inherit_quotation_gp" model="ir.ui.view">
    <field name="name">sale.order.form.quotation.gp</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='order_line']/list" position="attributes">
        <attribute name="editable">bottom</attribute>
      </xpath>
      <xpath expr="//field[@name='order_line']/list/field[@name='price_total']" position="after">
        <field name="custom_cost" groups="quote_management.group_sales_manager_approval"/>
        <field name="unit_cost" groups="quote_management.group_sales_manager_approval"/>
        <field name="line_cost" groups="quote_management.group_sales_manager_approval"/>
        <field name="gp" groups="quote_management.group_sales_manager_approval"/>
        <field name="gp_percent" groups="quote_management.group_sales_manager_approval"/>
        <field name="product_nature" groups="quote_management.group_sales_manager_approval"/>
        <field name="discount" groups="quote_management.group_sales_manager_approval"/>
        <field name="approval_required" readonly="1"/>
        <field name="approved_by_manager" groups="quote_management.group_sales_manager_approval"/>
      </xpath>

      <xpath expr="//field[@name='order_line']/form" position="inside">
        <group string="Cost &amp; GP (Manager Only)" groups="quote_management.group_sales_manager_approval">
          <field name="custom_cost"/>
          <field name="unit_cost" readonly="1"/>
          <field name="line_cost" readonly="1"/>
          <field name="gp" readonly="1"/>
          <field name="gp_percent" readonly="1"/>
          <field name="product_nature"/>
          <field name="discount"/>
          <field name="approval_required" readonly="1"/>
          <field name="approved_by_manager" groups="quote_management.group_sales_manager_approval"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>