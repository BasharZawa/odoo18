<odoo>

    <record id="view_api_sent_invoice_tree" model="ir.ui.view">
        <field name="name">api.sent.invoice.tree</field>
        <field name="model">api.sent.invoice</field>
        <field name="arch" type="xml">
            <tree string="API Sent Invoices">
                <field name="move_name" readonly="1"/>
                <field name="partner_id"  readonly="1"/>
                <field name="amount_total"  readonly="1"/>
                <field name="sent_date"  readonly="1"/>
                <field name="success"  readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="view_api_sent_invoice_form" model="ir.ui.view">
        <field name="name">api.sent.invoice.form</field>
        <field name="model">api.sent.invoice</field>
        <field name="arch" type="xml">
            <form string="API Sent Invoice">
                 <header>
                <button name="resend_invoice_form_to_api"
                        type="object"
                        string="Resend to API"
                        class="btn-primary"/>
            </header>
                <sheet>
                    <group>
                        <field name="move_id" readonly="1"/>
                        <field name="sent_date" readonly="1"/>
                        <field name="success" readonly="1"/>
                        <field name="response" readonly="1"/>

                    </group>


                </sheet>
            </form>
        </field>
    </record>

<record id="server_action_resend_invoice" model="ir.actions.server">
    <field name="name">Resend Invoice to API</field>
    <field name="model_id" ref="model_api_sent_invoice"/>
    <field name="binding_model_id" ref="model_api_sent_invoice"/>
    <field name="binding_type">action</field>
    <field name="state">code</field>

    <field name="code">
     records.resend_invoice_to_api()
    </field>
</record>

    <record id="action_api_sent_invoice" model="ir.actions.act_window">
        <field name="name">API Sent Invoices</field>
        <field name="res_model">api.sent.invoice</field>
        <field name="view_mode">tree,form</field>
    </record>


</odoo>