<odoo>
    <record id="view_company_einvoice_form" model="ir.ui.view">
       <field name="name">res.company.form.custom</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">


             <xpath expr="//sheet//field" position="attributes">
                <attribute name="readonly">1</attribute>
             </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="E-Invoice Info">
                    <group>
                        <field name="tin" attrs="{'readonly': False}"/>
                        <field name="internal_code" attrs="{'readonly': False}"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>


    <record id="view_res_company_tree_custom" model="ir.ui.view">
         <field name="name">res.partner.tree.custom</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="tin"/>
                <field name="internal_code"/>
            </xpath>
        </field>
    </record>


       <record id="action_einv_company_list" model="ir.actions.act_window">
          <field name="name">Companies</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">tree,form</field>

    </record>

</odoo>






















