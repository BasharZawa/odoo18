<odoo>
    <!-- Form view extension -->
    <record id="view_partner_einvoice_form" model="ir.ui.view">
         <field name="name">res.partner.form.custom</field>
      <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>

    <field name="arch" type="xml">

    <xpath expr="//notebook" position="inside">
                <page string="E-Invoice Info" name="einv_info">
                    <group>
                        <field name="tin"/>
                        <field name="internal_code"/>
                    </group>
                </page>
            </xpath>
    </field>
    </record>

    <!-- Tree view extension -->
    <record id="view_res_partner_tree_custom" model="ir.ui.view">
         <field name="name">res.partner.tree.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="tin"/>
                <field name="internal_code"/>
            </xpath>
        </field>
    </record>

    <!-- Action -->
    <record id="action_einv_customer_list" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_res_partner_tree_custom"/>

        <field name="views" eval="[
            (ref('view_res_partner_tree_custom'), 'tree'),
            (ref('view_partner_einvoice_form'), 'form')
        ]"/>
         <field name="domain">[('customer_rank','&gt;',0)]</field>
        </record>

</odoo>