<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_timesheet_approval_request_form_inherit" model="ir.ui.view">
        <field name="name">approval.request.form.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='request_details']" position="inside">
                <field name="has_supervisor" invisible="1"/>
                <field name="workorder_id" invisible="has_supervisor == 'no'" readonly="1"/>
                <field name="timesheet_employee" invisible="has_supervisor == 'no'" readonly="1"/>
                <field name="timesheet_hours" invisible="has_supervisor == 'no'" readonly="1"/>
                <field name="timesheet_supervisor_hours" invisible="has_supervisor == 'no'" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
