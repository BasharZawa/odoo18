<odoo>
    <data>
        <record id="view_appointment_form" model="ir.ui.view">
            <field name="name">appointment.form</field>
            <field name="model">appointment</field>
            <field name="arch" type="xml">
                <form string="Appointment">
                    <header>
                        <button name="print_appointment" type="object" string="Print" 
                            confirm="Are you sure you want to print this appointment?"
                            class="oe_highlight"
                            help="Print the appointment details"
                        />

                        <field name="status" widget="statusbar" 
                                 statusbar_visible="new,scheduled,completed,canceled" 
                                options="{'clickable': '1'}"
                        />
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="patient_id"/>
                            <field name="status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_appointment_list" model="ir.ui.view">
            <field name="name">appointment.list</field>
            <field name="model">appointment</field>
            <field name="arch" type="xml">
                <list string="Appointments">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="patient_id"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <record id="action_appointment_views" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">appointment</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_appointment_list"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create the first appointment
                </p>
            </field>
        </record>
    </data>
</odoo>