<odoo>
    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">patient.form</field>
        <field name="model">patient</field>
        <field name="arch" type="xml">
            <form string="Patient Form">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                        </group>
                    </group>
                </sheet>

                <chatter/>

            </form>      
        </field>  
    </record>

    <record id="view_patient_list" model="ir.ui.view">
        <field name="name">patient.list</field>
        <field name="model">patient</field>
        <field name="arch" type="xml">
            <list string="Patient List">
                <field name="name"/>
                <field name="age"/>
            </list>
        </field>
    </record>

    <record id="action_patient_views" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">patient</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_patient_list"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create the first patient
            </p>
            <p>
                Click to create a new patient.
            </p>
        </field>
    </record>

    <!-- menu -->

    <menuitem 
        id="menu_sedco_root"
        name="Sedco Management"
        sequence="1"
        web_icon="sedco_management/static/img/icon.jpeg"
    />
     
    <menuitem 
        id="menu_patient_view"
        name="Patients"
        parent="menu_sedco_root"
        action="action_patient_views"
    />
        
</odoo>