{
    "version": "0.2.0",
    "configurations": [
{
            "name": "Launch Odoo with venv",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/odoo-bin",
            "args": [
                "-c",
                "${workspaceFolder}/odoo.conf",
                "-d",
                "OdooE",
                "-u",
                "sedco_metabase_reports,account_extended_ept"
            ],
            "python": "${workspaceFolder}/.venv/bin/python3",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        }
    ]
}