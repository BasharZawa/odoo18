<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Process Start Wizard Views -->
        <record id="view_bmp_process_start_form" model="ir.ui.view">
            <field name="name">bmp.process.start.form</field>
            <field name="model">bmp.process.start</field>
            <field name="arch" type="xml">
                <form string="Start Process">
                    <sheet>
                        <div class="oe_title">
                            <h1>Start BPMN Process</h1>
                        </div>
                        <group>
                            <group>
                                <field name="process_definition_id"/>
                                <field name="assigned_user_id"/>
                                <field name="priority"/>
                                <field name="auto_start"/>
                            </group>
                            <group>
                                <field name="related_record_model" readonly="1"/>
                                <field name="related_record_id" readonly="1"/>
                            </group>
                        </group>
                        
                        <group string="Initial Variables">
                            <field name="initial_variables" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_start_process" string="Start Process" type="object" class="btn-primary"/>
                        <button name="action_preview_variables" string="Preview Variables" type="object" class="btn-secondary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Process Start Wizard Action -->
        <record id="action_bmp_process_start" model="ir.actions.act_window">
            <field name="name">Start Process</field>
            <field name="res_model">bmp.process.start</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_bmp_process_start_form"/>
            <field name="target">new</field>
        </record>
        
    </data>
</odoo>