<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Dashboard View -->
        <record id="view_bmp_dashboard" model="ir.ui.view">
            <field name="name">bmp.dashboard</field>
            <field name="model">bmp.process.instance</field>
            <field name="arch" type="xml">
                <form string="BPMN Dashboard">
                    <sheet>
                        <div class="o_bmp_dashboard">
                            <div class="row">
                                <div class="col-lg-3 o_bmp_dashboard_item">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>Active Processes</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div class="o_bmp_dashboard_number">
                                                <span class="o_bmp_dashboard_value">0</span>
                                            </div>
                                            <div class="o_bmp_dashboard_desc">
                                                Currently running process instances
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-3 o_bmp_dashboard_item">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>My Tasks</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div class="o_bmp_dashboard_number">
                                                <span class="o_bmp_dashboard_value">0</span>
                                            </div>
                                            <div class="o_bmp_dashboard_desc">
                                                Tasks assigned to me
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-3 o_bmp_dashboard_item">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>Overdue Tasks</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div class="o_bmp_dashboard_number">
                                                <span class="o_bmp_dashboard_value text-danger">0</span>
                                            </div>
                                            <div class="o_bmp_dashboard_desc">
                                                Tasks past their due date
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-3 o_bmp_dashboard_item">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>Completed Today</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div class="o_bmp_dashboard_number">
                                                <span class="o_bmp_dashboard_value text-success">0</span>
                                            </div>
                                            <div class="o_bmp_dashboard_desc">
                                                Processes completed today
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row mt-4">
                                <div class="col-lg-6">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>Recent Activity</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div id="bmp_recent_activity">
                                                <!-- Recent activity will be loaded here -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-6">
                                    <div class="o_bmp_dashboard_block">
                                        <div class="o_bmp_dashboard_block_title">
                                            <h3>Quick Actions</h3>
                                        </div>
                                        <div class="o_bmp_dashboard_block_content">
                                            <div class="o_bmp_quick_actions">
                                                <button class="btn btn-primary" type="button" onclick="window.location.href='/web#action=bmp_engine_copilot.action_bmp_process_definition'">
                                                    <i class="fa fa-plus"></i> Create Process
                                                </button>
                                                <button class="btn btn-success" type="button" onclick="window.location.href='/web#action=bmp_engine_copilot.action_bmp_task_instance_my_tasks'">
                                                    <i class="fa fa-tasks"></i> My Tasks
                                                </button>
                                                <button class="btn btn-info" type="button" onclick="window.location.href='/web#action=bmp_engine_copilot.action_bmp_process_instance'">
                                                    <i class="fa fa-cogs"></i> Process Instances
                                                </button>
                                                <button class="btn btn-warning" type="button" onclick="window.location.href='/web#action=bmp_engine_copilot.action_bmp_activity_log'">
                                                    <i class="fa fa-history"></i> Activity Logs
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Dashboard Action -->
        <record id="action_bmp_dashboard" model="ir.actions.act_window">
            <field name="name">BPMN Dashboard</field>
            <field name="res_model">bmp.process.instance</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_bmp_dashboard"/>
            <field name="target">fullscreen</field>
            <field name="context">{}</field>
        </record>
        
    </data>
</odoo>