<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Process Instance Views -->
        <record id="view_bmp_process_instance_tree" model="ir.ui.view">
            <field name="name">bmp.process.instance.tree</field>
            <field name="model">bmp.process.instance</field>
            <field name="arch" type="xml">
                <tree string="Process Instances">
                    <field name="display_name"/>
                    <field name="process_definition_id"/>
                    <field name="state" decoration-info="state=='draft'" decoration-warning="state=='running'" 
                           decoration-success="state=='completed'" decoration-danger="state=='failed'"/>
                    <field name="progress_percentage" widget="percentage"/>
                    <field name="started_at"/>
                    <field name="duration"/>
                    <field name="created_by"/>
                    <field name="assigned_user_id"/>
                </tree>
            </field>
        </record>
        
        <record id="view_bmp_process_instance_form" model="ir.ui.view">
            <field name="name">bmp.process.instance.form</field>
            <field name="model">bmp.process.instance</field>
            <field name="arch" type="xml">
                <form string="Process Instance">
                    <header>
                        <button name="action_start" string="Start" type="object" class="btn-primary" 
                                invisible="state != 'draft'"/>
                        <button name="action_suspend" string="Suspend" type="object" 
                                invisible="state != 'running'"/>
                        <button name="action_resume" string="Resume" type="object" 
                                invisible="state != 'suspended'"/>
                        <button name="action_cancel" string="Cancel" type="object" 
                                invisible="state in ['completed', 'failed', 'cancelled']"/>
                        <button name="action_view_tasks" string="View Tasks" type="object"/>
                        <button name="action_view_logs" string="View Logs" type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,running,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="display_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="process_definition_id"/>
                                <field name="assigned_user_id"/>
                                <field name="priority"/>
                                <field name="current_activity"/>
                            </group>
                            <group>
                                <field name="started_at" readonly="1"/>
                                <field name="ended_at" readonly="1"/>
                                <field name="duration" readonly="1"/>
                                <field name="progress_percentage" widget="percentage" readonly="1"/>
                            </group>
                        </group>
                        
                        <group string="Related Record" invisible="not related_record_model">
                            <field name="related_record_model" readonly="1"/>
                            <field name="related_record_id" readonly="1"/>
                            <field name="related_record_name" readonly="1"/>
                        </group>
                        
                        <notebook>
                            <page string="Tasks">
                                <group>
                                    <group>
                                        <field name="total_tasks" readonly="1"/>
                                        <field name="completed_tasks" readonly="1"/>
                                        <field name="active_tasks" readonly="1"/>
                                    </group>
                                </group>
                                <field name="task_instances" readonly="1">
                                    <tree>
                                        <field name="task_name"/>
                                        <field name="task_type"/>
                                        <field name="status" decoration-info="status=='ready'" 
                                               decoration-warning="status in ['claimed','in_progress']" 
                                               decoration-success="status=='completed'" 
                                               decoration-danger="status=='failed'"/>
                                        <field name="assigned_user_id"/>
                                        <field name="due_date"/>
                                        <field name="created_at"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Variables">
                                <field name="process_variables" readonly="1">
                                    <tree>
                                        <field name="key"/>
                                        <field name="type"/>
                                        <field name="display_value"/>
                                        <field name="scope"/>
                                        <field name="is_readonly"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Activity Log">
                                <field name="activity_logs" readonly="1">
                                    <tree>
                                        <field name="timestamp"/>
                                        <field name="action_type"/>
                                        <field name="actor_id"/>
                                        <field name="details"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Error Details" invisible="state != 'failed'">
                                <field name="error_message" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_bmp_process_instance_search" model="ir.ui.view">
            <field name="name">bmp.process.instance.search</field>
            <field name="model">bmp.process.instance</field>
            <field name="arch" type="xml">
                <search>
                    <field name="display_name"/>
                    <field name="process_definition_id"/>
                    <field name="assigned_user_id"/>
                    <field name="created_by"/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                    <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                    <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                    <filter string="My Instances" name="my_instances" domain="[('created_by', '=', uid)]"/>
                    <filter string="Assigned to Me" name="assigned_to_me" domain="[('assigned_user_id', '=', uid)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Process Definition" name="process_definition" domain="[]" 
                                context="{'group_by': 'process_definition_id'}"/>
                        <filter string="State" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                        <filter string="Assigned User" name="assigned_user" domain="[]" 
                                context="{'group_by': 'assigned_user_id'}"/>
                        <filter string="Created By" name="created_by" domain="[]" 
                                context="{'group_by': 'created_by'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_bmp_process_instance" model="ir.actions.act_window">
            <field name="name">Process Instances</field>
            <field name="res_model">bmp.process.instance</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bmp_process_instance_search"/>
            <field name="context">{'search_default_running': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No process instances found!
                </p>
                <p>
                    Process instances are created when you start a process from a process definition.
                    They represent the actual execution of your business processes.
                </p>
            </field>
        </record>
        
        <record id="action_bmp_process_instance_my" model="ir.actions.act_window">
            <field name="name">My Process Instances</field>
            <field name="res_model">bmp.process.instance</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bmp_process_instance_search"/>
            <field name="context">{'search_default_my_instances': 1}</field>
            <field name="domain">[('created_by', '=', uid)]</field>
        </record>
        
    </data>
</odoo>