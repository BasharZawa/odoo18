<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Activity Log Views -->
        <record id="view_bmp_activity_log_tree" model="ir.ui.view">
            <field name="name">bmp.activity.log.tree</field>
            <field name="model">bmp.activity.log</field>
            <field name="arch" type="xml">
                <tree string="Activity Logs">
                    <field name="timestamp"/>
                    <field name="action_type"/>
                    <field name="process_instance_id"/>
                    <field name="task_instance_id"/>
                    <field name="actor_name"/>
                    <field name="element_name"/>
                    <field name="level"/>
                    <field name="details"/>
                </tree>
            </field>
        </record>
        
        <record id="view_bmp_activity_log_form" model="ir.ui.view">
            <field name="name">bmp.activity.log.form</field>
            <field name="model">bmp.activity.log</field>
            <field name="arch" type="xml">
                <form string="Activity Log">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="display_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="process_instance_id"/>
                                <field name="task_instance_id"/>
                                <field name="action_type"/>
                                <field name="category"/>
                                <field name="level"/>
                            </group>
                            <group>
                                <field name="timestamp"/>
                                <field name="actor_id"/>
                                <field name="element_id"/>
                                <field name="element_name"/>
                                <field name="element_type"/>
                            </group>
                        </group>
                        <group string="Details">
                            <field name="details" nolabel="1"/>
                        </group>
                        <group string="Value Changes" invisible="not old_values and not new_values">
                            <group>
                                <field name="old_values" widget="ace" options="{'mode': 'json'}"/>
                            </group>
                            <group>
                                <field name="new_values" widget="ace" options="{'mode': 'json'}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_bmp_activity_log_search" model="ir.ui.view">
            <field name="name">bmp.activity.log.search</field>
            <field name="model">bmp.activity.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="details"/>
                    <field name="process_instance_id"/>
                    <field name="task_instance_id"/>
                    <field name="actor_id"/>
                    <field name="element_name"/>
                    <filter string="My Actions" name="my_actions" domain="[('actor_id', '=', uid)]"/>
                    <filter string="Process Actions" name="process_actions" domain="[('category', '=', 'process')]"/>
                    <filter string="Task Actions" name="task_actions" domain="[('category', '=', 'task')]"/>
                    <filter string="System Events" name="system_events" domain="[('category', '=', 'system')]"/>
                    <filter string="Errors" name="errors" domain="[('level', '=', 'error')]"/>
                    <filter string="Warnings" name="warnings" domain="[('level', '=', 'warning')]"/>
                    <filter string="Today" name="today" domain="[('timestamp', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                    <group expand="0" string="Group By">
                        <filter string="Process" name="group_process" domain="[]" context="{'group_by': 'process_instance_id'}"/>
                        <filter string="Action Type" name="group_action" domain="[]" context="{'group_by': 'action_type'}"/>
                        <filter string="Category" name="group_category" domain="[]" context="{'group_by': 'category'}"/>
                        <filter string="Level" name="group_level" domain="[]" context="{'group_by': 'level'}"/>
                        <filter string="Actor" name="group_actor" domain="[]" context="{'group_by': 'actor_id'}"/>
                        <filter string="Date" name="group_date" domain="[]" context="{'group_by': 'timestamp:day'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_bmp_activity_log" model="ir.actions.act_window">
            <field name="name">Activity Logs</field>
            <field name="res_model">bmp.activity.log</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bmp_activity_log_search"/>
            <field name="context">{'search_default_today': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No activity logs found!
                </p>
                <p>
                    Activity logs track all actions performed on processes and tasks.
                    They provide a complete audit trail of process execution.
                </p>
            </field>
        </record>
        
    </data>
</odoo>