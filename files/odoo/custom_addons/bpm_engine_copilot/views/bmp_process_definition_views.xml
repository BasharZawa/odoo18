<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Process Definition Views -->
        <record id="view_bmp_process_definition_tree" model="ir.ui.view">
            <field name="name">bmp.process.definition.tree</field>
            <field name="model">bmp.process.definition</field>
            <field name="arch" type="xml">
                <tree string="Process Definitions">
                    <field name="name"/>
                    <field name="version"/>
                    <field name="is_active"/>
                    <field name="instance_count"/>
                    <field name="active_instance_count"/>
                    <field name="created_at"/>
                    <field name="created_by"/>
                </tree>
            </field>
        </record>
        
        <record id="view_bmp_process_definition_form" model="ir.ui.view">
            <field name="name">bmp.process.definition.form</field>
            <field name="model">bmp.process.definition</field>
            <field name="arch" type="xml">
                <form string="Process Definition">
                    <header>
                        <button name="action_activate" string="Activate" type="object" class="btn-primary" 
                                invisible="is_active"/>
                        <button name="action_create_instance" string="Create Instance" type="object" 
                                class="btn-success" invisible="not is_active"/>
                        <button name="action_view_instances" string="View Instances" type="object"/>
                        <field name="is_active" widget="boolean_toggle"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="display_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="version"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name="created_by" readonly="1"/>
                                <field name="created_at" readonly="1"/>
                                <field name="updated_at" readonly="1"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="BPMN Definition">
                                <field name="xml_data" widget="ace" options="{'mode': 'xml'}"/>
                            </page>
                            <page string="Statistics">
                                <group>
                                    <group>
                                        <field name="instance_count" readonly="1"/>
                                        <field name="active_instance_count" readonly="1"/>
                                        <field name="completed_instance_count" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Process Instances">
                                <field name="process_instances" readonly="1">
                                    <tree>
                                        <field name="id"/>
                                        <field name="state"/>
                                        <field name="started_at"/>
                                        <field name="progress_percentage"/>
                                        <field name="created_by"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_bmp_process_definition_search" model="ir.ui.view">
            <field name="name">bmp.process.definition.search</field>
            <field name="model">bmp.process.definition</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="version"/>
                    <field name="description"/>
                    <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('is_active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Created By" name="created_by" domain="[]" context="{'group_by': 'created_by'}"/>
                        <filter string="Active" name="group_active" domain="[]" context="{'group_by': 'is_active'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_bmp_process_definition" model="ir.actions.act_window">
            <field name="name">Process Definitions</field>
            <field name="res_model">bmp.process.definition</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bmp_process_definition_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first BPMN process definition!
                </p>
                <p>
                    Process definitions contain the BPMN 2.0 XML that defines your business process workflow.
                    You can model your processes using BPMN tools and import the XML here.
                </p>
            </field>
        </record>
        
    </data>
</odoo>